    "def build_ms_cbam_transformer(input_shape=(224,224,3), num_classes=8, name='model'):\n",
    "    inp  = Input(shape=input_shape, name='input_image')\n",
    "    stem = Conv2D(32,(7,7),strides=(2,2),padding='same',\n",
    "                  kernel_regularizer=l2(1e-4),name='stem_conv')(inp)\n",
    "    stem = BatchNormalization()(stem); stem = Activation('relu')(stem)\n",
    "    stem = MaxPooling2D((3,3),strides=(2,2),padding='same')(stem)\n",
    "\n",
    "    A = conv_block(stem,32); A = identity_block(A,32); A = identity_block(A,32); A = cbam_block(A)\n",
    "    A = conv_block(A,64);   A = identity_block(A,64);  A = identity_block(A,64);  A = cbam_block(A)\n",
    "    A = conv_block(A,128);  A = identity_block(A,128)\n",
    "    A_out, A_sp = cbam_block(A, ratio=16, return_attn=True)\n",
    "    attn_flat   = FlattenSpatialAttn(name='attn_flat')(A_sp)\n",
    "    A_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(\n",
    "             Add()([GlobalAveragePooling2D()(A_out), GlobalMaxPooling2D()(A_out)]))\n",
    "\n",
    "    B = conv_block(stem,32); B = identity_block(B,32); B = cbam_block(B)\n",
    "    B = conv_block(B,64);   B = identity_block(B,64);  B = cbam_block(B)\n",
    "    B = MaxPooling2D((3,3),padding='same')(B)\n",
    "    B_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(\n",
    "             Add()([GlobalAveragePooling2D()(B), GlobalMaxPooling2D()(B)]))\n",
    "\n",
    "    C2 = GlobalAveragePooling2D()(Conv2D(32,(1,1),activation='relu')(\n",
    "         AveragePooling2D((2,2),strides=(2,2),padding='same')(stem)))\n",
    "    C4 = GlobalAveragePooling2D()(Conv2D(32,(1,1),activation='relu')(\n",
    "         AveragePooling2D((4,4),strides=(4,4),padding='same')(stem)))\n",
    "    C_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(Concatenate()([C2,C4]))\n",
    "\n",
    "    seq = Concatenate(axis=1,name='anatomical_sequence')([\n",
    "        Reshape((1,D_MODEL))(A_feat), Reshape((1,D_MODEL))(B_feat), Reshape((1,D_MODEL))(C_feat)])\n",
    "\n",
    "    agg = build_transformer_head(seq, d_model=D_MODEL, num_heads=2,\n",
    "                                 dropout_rate=0.2, l2_reg=2e-4, name_prefix=f'{name}_')\n",
    "\n",
    "    out = Dense(128,activation='relu',kernel_regularizer=l2(1e-4))(agg)\n",
    "    out = BatchNormalization()(out); out = Dropout(0.4)(out)\n",
    "    out = Dense(64, activation='relu',kernel_regularizer=l2(1e-4))(out)\n",
    "    out = Dropout(0.3)(out)\n",
    "    predictions = Dense(num_classes, activation='softmax', name='predictions')(out)\n",
    "    return Model(inputs=inp, outputs=[predictions, attn_flat], name=name)\n",
    "\n",
    "student = build_ms_cbam_transformer(name='student')\n",
    "teacher = build_ms_cbam_transformer(name='teacher')\n",
