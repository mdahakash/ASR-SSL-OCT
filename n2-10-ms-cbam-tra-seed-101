    "from tensorflow.keras.preprocessing.image import ImageDataGenerator\n",
    "\n",
    "def enhance_image(image):\n",
    "    img_uint8 = np.clip(image, 0, 255).astype(np.uint8)\n",
    "    lab = cv2.cvtColor(img_uint8, cv2.COLOR_RGB2LAB)\n",
    "    l, a, b = cv2.split(lab)\n",
    "    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))\n",
    "    l = clahe.apply(l)\n",
    "    enhanced = cv2.cvtColor(cv2.merge([l, a, b]), cv2.COLOR_LAB2RGB)\n",
    "    gaussian  = cv2.GaussianBlur(enhanced, (5,5), 1.0)\n",
    "    return cv2.addWeighted(enhanced, 1.5, gaussian, -0.5, 0).astype(np.float32)\n",
    "\n",
    "def cutout(img_norm, mask_sizes=(16,32), p=0.5):\n",
    "    if np.random.random() >= p: return img_norm\n",
    "    img = img_norm.copy(); h, w = img.shape[:2]\n",
    "    ms = int(np.random.choice(mask_sizes))\n",
    "    cx = np.random.randint(ms//2, max(ms//2+1, w-ms//2+1))\n",
    "    cy = np.random.randint(ms//2, max(ms//2+1, h-ms//2+1))\n",
    "    x1=max(cx-ms//2,0); x2=min(cx+ms//2,w)\n",
    "    y1=max(cy-ms//2,0); y2=min(cy+ms//2,h)\n",
    "    img[y1:y2,x1:x2,:] = 0.0; return img\n",
    "\n",
    "def enhance_with_cutout(image):\n",
    "    e = enhance_image(image)/255.0; e = cutout(e)\n",
    "    return (e*255.0).astype(np.float32)\n",
    "\n",
    "labeled_gen   = ImageDataGenerator(rescale=1./255, preprocessing_function=enhance_with_cutout,\n",
    "    rotation_range=15, width_shift_range=0.15, height_shift_range=0.15,\n",
    "    shear_range=0.08, zoom_range=0.15, horizontal_flip=True, fill_mode='constant', cval=0.0)\n",
