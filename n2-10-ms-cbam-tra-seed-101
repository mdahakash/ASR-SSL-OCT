    "\n",
    "    # v3: T=0.8 (softer than v2's T=0.5 which caused ATC collapse)\n",
    "    t_probs = sharpen(t_probs_raw, T=SHARPEN_TEMP)\n",
    "\n",
    "    # ── Student: GradientTape ─────────────────────────────────────────────────\n",
    "    with tf.GradientTape() as tape:\n",
    "        # Supervised loss\n",
    "        s_probs_lab, _ = student(x_lab, training=True)\n",
    "        l_sup = focal_loss_fn(y_lab, s_probs_lab)\n",
    "\n",
    "        # Same weak-aug view as teacher — ATP at token level only\n",
    "        s_seq    = student_seq_model(x_unlab_weak, training=True)\n",
    "        s_seq_pe = s_pos_enc(s_seq, training=True)\n",
    "        s_seq_atp = apply_atp(s_seq_pe)          # token perturbation only\n",
    "\n",
    "        s_enc, s_attn_w = s_tb(s_seq_atp, training=True, return_attention=True)\n",
    "        s_agg = tf.reduce_mean(s_enc, axis=1) + tf.reduce_max(s_enc, axis=1)\n",
    "\n",
    "        # Pre-identified classifier layers (FIX 2 — no layer-walking loop)\n",
    "        x_cls = s_d128(s_agg,  training=True)\n",
    "        x_cls = s_bn(x_cls,    training=True)\n",
    "        x_cls = s_drop1(x_cls, training=True)\n",
    "        x_cls = s_d64(x_cls,   training=True)\n",
    "        x_cls = s_drop2(x_cls, training=True)\n",
    "        s_probs_unlab = tf.nn.softmax(s_pred(x_cls, training=True), axis=-1)\n",
    "\n",
    "        l_cons = eadw_consistency_loss(t_probs, s_probs_unlab)\n",
    "        l_atc  = atc_loss(t_attn_w, s_attn_w)\n",
    "        l_adr  = adr_loss(t_attn_w, s_attn_w)\n",
    "\n",
    "        total = l_sup + w_cons*l_cons + w_atc*l_atc + w_adr*l_adr\n",
    "\n",
    "    grads = tape.gradient(total, student.trainable_variables)\n",
    "    valid = [(g,v) for g,v in zip(grads,student.trainable_variables) if g is not None]\n",
    "    ssl_optimizer.apply_gradients(valid)\n",
    "    return total, l_sup, l_cons, l_atc, l_adr\n",
    "\n",
    "\n",
    "print('Train steps ready (v3).')\n"
   ]
