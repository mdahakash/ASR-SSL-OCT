    "def atp_feature_mask(seq, mask_frac=ATP_MASK_FRAC):\n",
    "    mask = tf.cast(tf.random.uniform(tf.shape(seq)) >= mask_frac, seq.dtype)\n",
    "    return seq * mask\n",
    "\n",
    "def atp_token_shuffle(seq, shuffle_p=ATP_SHUFFLE_P):\n",
    "    B = tf.shape(seq)[0]\n",
    "    sw = tf.cast(tf.random.uniform([B]) < shuffle_p, seq.dtype)\n",
    "    sw3 = tf.reshape(sw, [B,1,1])\n",
    "    fine=seq[:,0:1,:]; coarse=seq[:,1:2,:]; ctx=seq[:,2:3,:]\n",
    "    nf = fine   + sw3*(coarse-fine)\n",
    "    nc = coarse + sw3*(fine-coarse)\n",
    "    return tf.concat([nf, nc, ctx], axis=1)\n",
    "\n",
    "def apply_atp(seq):\n",
    "    seq = atp_feature_mask(seq); seq = atp_token_shuffle(seq); return seq\n",
    "\n",
    "print(f'ATP: mask_frac={ATP_MASK_FRAC}, shuffle_p={ATP_SHUFFLE_P}')\n"
