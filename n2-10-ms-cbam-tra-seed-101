    "def ema_update(student_model, teacher_model, decay=EMA_DECAY):\n",
    "    for t_var, s_var in zip(teacher_model.variables, student_model.variables):\n",
    "        if t_var.trainable:\n",
    "            t_var.assign(decay*t_var + (1.0-decay)*s_var)\n",
    "\n",
    "@tf.function\n",
    "def fast_predict(model, xb):\n",
    "    preds, _ = model(xb, training=False); return preds\n",
    "\n",
    "def validate_teacher(model, flow):\n",
    "    all_probs, all_trues = [], []\n",
    "    flow.reset()\n",
    "    for _ in range(len(flow)):\n",
    "        xb, yb = next(flow)\n",
    "        all_probs.append(fast_predict(model, xb).numpy())\n",
    "        all_trues.append(yb)\n",
    "    probs = np.concatenate(all_probs); trues = np.concatenate(all_trues)\n",
    "    acc   = accuracy_score(np.argmax(trues,1), np.argmax(probs,1))\n",
    "    try:    mauc = roc_auc_score(trues, probs, average='macro', multi_class='ovr')\n",
    "    except: mauc = 0.0\n",
    "    return acc, mauc\n",
    "\n",
    "print('ema_update and validate_teacher ready.')\n"
   ]
