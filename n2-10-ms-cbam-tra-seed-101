    "class SinusoidalPositionalEncoding(tf.keras.layers.Layer):\n",
    "    def __init__(self, max_len=3, d_model=64, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.max_len = max_len; self.d_model = d_model\n",
    "        pe = np.zeros((max_len, d_model), dtype=np.float32)\n",
    "        for pos in range(max_len):\n",
    "            for i in range(0, d_model, 2):\n",
    "                angle = pos / (10000.0 ** (2 * i / d_model))\n",
    "                pe[pos, i] = math.sin(angle)\n",
    "                if i + 1 < d_model: pe[pos, i+1] = math.cos(angle)\n",
    "        self.pe = tf.constant(pe[np.newaxis], dtype=tf.float32)\n",
    "    def call(self, x): return x + self.pe[:, :tf.shape(x)[1], :]\n",
    "    def get_config(self):\n",
    "        cfg = super().get_config(); cfg.update({'max_len':self.max_len,'d_model':self.d_model}); return cfg\n",
    "\n",
    "\n",
    "class TransformerEncoderBlock(tf.keras.layers.Layer):\n",
    "    def __init__(self, d_model=64, num_heads=2, dropout_rate=0.2, l2_reg=2e-4, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.d_model=d_model; self.num_heads=num_heads\n",
    "        self.dropout_rate=dropout_rate; self.l2_reg=l2_reg\n",
    "        key_dim = d_model // num_heads\n",
    "        self.ln1    = LayerNormalization(epsilon=1e-6)\n",
    "        self.mhsa   = MultiHeadAttention(num_heads=num_heads, key_dim=key_dim, dropout=dropout_rate)\n",
    "        self.drop1  = Dropout(dropout_rate)\n",
    "        self.ln2    = LayerNormalization(epsilon=1e-6)\n",
    "        self.ffn_w1 = Dense(4*d_model, activation='gelu', kernel_regularizer=l2(l2_reg))\n",
    "        self.ffn_w2 = Dense(d_model, kernel_regularizer=l2(l2_reg))\n",
    "        self.drop2  = Dropout(dropout_rate)\n",
    "\n",
    "    def call(self, x, training=False, return_attention=False):\n",
    "        x_ln = self.ln1(x)\n",
    "        if return_attention:\n",
    "            attn_out, attn_w = self.mhsa(x_ln, x_ln, training=training, return_attention_scores=True)\n",
    "        else:\n",
    "            attn_out = self.mhsa(x_ln, x_ln, training=training); attn_w = None\n",
    "        attn_out = self.drop1(attn_out, training=training); x = x + attn_out\n",
    "        x_ln = self.ln2(x)\n",
    "        ffn  = self.ffn_w2(self.ffn_w1(x_ln))\n",
    "        ffn  = self.drop2(ffn, training=training); out = x + ffn\n",
    "        return (out, attn_w) if return_attention else out\n",
    "\n",
    "    def get_config(self):\n",
    "        cfg = super().get_config()\n",
    "        cfg.update({'d_model':self.d_model,'num_heads':self.num_heads,\n",
    "                    'dropout_rate':self.dropout_rate,'l2_reg':self.l2_reg}); return cfg\n",
    "\n",
    "\n",
    "def build_transformer_head(seq_input, d_model=64, num_heads=2,\n",
    "                            dropout_rate=0.2, l2_reg=2e-4, name_prefix=''):\n",
    "    x = SinusoidalPositionalEncoding(max_len=3, d_model=d_model,\n",
    "                                     name=f'{name_prefix}pos_enc')(seq_input)\n",
    "    x = TransformerEncoderBlock(d_model=d_model, num_heads=num_heads,\n",
    "                                dropout_rate=dropout_rate, l2_reg=l2_reg,\n",
    "                                name=f'{name_prefix}transformer_block')(x)\n",
    "    return Add()([ReduceMeanAxis1()(x), ReduceMaxAxis1()(x)])\n",
    "\n",
    "\n",
    "class WarmupCosineDecay(tf.keras.optimizers.schedules.LearningRateSchedule):\n",
    "    def __init__(self, lr_max, lr_min, warmup_steps, total_steps, **kwargs):\n",
    "        super().__init__(**kwargs)\n",
    "        self.lr_max=float(lr_max); self.lr_min=float(lr_min)\n",
    "        self.warmup_steps=float(warmup_steps); self.total_steps=float(total_steps)\n",
    "    def __call__(self, step):\n",
    "        step = tf.cast(step, tf.float32)\n",
    "        warmup = self.lr_max * (step / self.warmup_steps)\n",
    "        cs = tf.maximum(step - self.warmup_steps, 0.0)\n",
    "        ct = tf.maximum(self.total_steps - self.warmup_steps, 1.0)\n",
    "        cosine = self.lr_min + 0.5*(self.lr_max-self.lr_min)*(1.0+tf.cos(math.pi*cs/ct))\n",
    "        return tf.where(step < self.warmup_steps, warmup, cosine)\n",
    "    def get_config(self):\n",
    "        return {'lr_max':self.lr_max,'lr_min':self.lr_min,\n",
    "                'warmup_steps':self.warmup_steps,'total_steps':self.total_steps}\n",
    "\n",
    "\n",
    "def focal_loss_fn(y_true, y_pred, gamma=2.0, label_smoothing=0.1, eps=1e-8):\n",
    "    num_cls  = tf.cast(tf.shape(y_true)[-1], tf.float32)\n",
    "    y_smooth = y_true*(1.0-label_smoothing) + label_smoothing/num_cls\n",
    "    y_pred   = tf.clip_by_value(y_pred, eps, 1.0-eps)\n",
    "    ce       = -y_smooth * tf.math.log(y_pred)\n",
    "    fw       = tf.pow(1.0-y_pred, gamma)\n",
    "    return tf.reduce_mean(tf.reduce_sum(_DEFAULT_CLASS_WEIGHTS*fw*ce, axis=-1))\n",
    "\n",
    "\n",
    "CUSTOM_OBJECTS = {\n",
    "    'SinusoidalPositionalEncoding': SinusoidalPositionalEncoding,\n",
    "    'TransformerEncoderBlock':      TransformerEncoderBlock,\n",
    "    'ReduceMeanAxis1': ReduceMeanAxis1, 'ReduceMaxAxis1': ReduceMaxAxis1,\n",
    "    'ChannelMean': ChannelMean, 'ChannelMax': ChannelMax,\n",
    "    'FlattenSpatialAttn': FlattenSpatialAttn,\n",
    "    'WarmupCosineDecay': WarmupCosineDecay, 'focal_loss_fn': focal_loss_fn,\n",
    "}\n",
    "print('Cell 4 ready.')\n"
   ]
