         in l.name: pe = l\n        if 'transformer_block' in l.name: tb = l\n    assert pe and tb; return pe, tb\n\ns_pos_enc, s_tb = get_transformer_layers(student)\nt_pos_enc, t_tb = get_transformer_layers(teacher)\nprint(f'Student: pos_enc={s_pos_enc.name}, tb={s_tb.name}')\n\n# ── Classifier layers — identified by name/type, NOT by slice ────────────────\ndef get_classifier_layers(model):\n    layers = list(model.layers)\n    # Dense(128) — last one (backbone has no Dense(128))\n    d128 = [l for l in layers if isinstance(l,Dense) and l.units==128][-1]\n    idx128 = layers.index(d128)\n    # BN after d128\n    bn    = next(l for l in layers[idx128:] if isinstance(l,BatchNormalization))\n    # Dropouts after d128\n    drops = [l for l in layers[idx128:] if isinstance(l,Dropout)]\n    assert len(drops) >= 2\n    drop1, drop2 = drops[0], drops[1]\n    # Dense(64) after d128 (not 'predictions')\n    d64   = next(l for l in layers[idx128:] if isinstance(l,Dense)\n                 and l.units==64 and l.name!='predictions')\n    pred  = model.get_layer('predictions')\n    return d128, bn, drop1, d64, drop2, pred\n\ns_d128, s_bn, s_drop1, s_d64, s_drop2, s_pred = get_classifier_layers(student)\nprint('Classifier layers:')\nfor name, layer in [('Dense(128)',s_d128),('BN',s_bn),('Drop1',s_drop1),\n                    ('Dense(64)',s_d64),('Drop2',s_drop2),('pred',s_pred)]:\n    print(f'  {name:12s}: {layer.name}')\n\n# ── v3 FIX 1: Warmup vars — explicit list, NOT a position slice ───────────────\n# Include: pos_enc, transformer_block, Dense(128), BN, Dense(64), predictions\n_warmup_layers = [s_pos_enc, s_tb, s_d128, s_bn, s_drop1, s_d64, s_drop2, s_pred]\n_warmup_vars   = []\nfor layer in _warmup_layers:\n    _warmup_vars.extend(layer.trainable_variables)\nprint(f'\\nWarmup trainable vars: {len(_warmup_vars)} '\n      f'(transformer+classifier, explicit list)')\n\n# ── Gradient connectivity check ───────────────────────────────────────────────\nprint('\\nGradient connectivity check...')\n_xu, _ = next(iter(unlabeled_flow_weak))\nwith tf.GradientTape() as _tape:\n    _seq    = student_seq_model(_xu[:4], training=True)\n    _seq_pe = s_pos_enc(_seq, training=True)\n    # ATP\n    _B = tf.shape(_seq_pe)[0]\n    _mask = tf.cast(tf.random.uniform(tf.shape(_seq_pe)) >= ATP_MASK_FRAC, _seq_pe.dtype)\n    _seq_atp = _seq_pe * _mask\n    _enc, _  = s_tb(_seq_atp, training=True, return_attention=True)\n    _agg     = tf.reduce_mean(_enc, axis=1) + tf.reduce_max(_enc, axis=1)\n    _x       = s_d128(_agg,  training=True)\n    _x       = s_bn(_x,      training=True)\n    _x       = s_drop1(_x,   training=True)\n    _x       = s_d64(_x,     training=True)\n    _x       = s_drop2(_x,   training=True)\n    _pu      = tf.nn.softmax(s_pred(_x), axis=-1)\n    _dummy   = tf.ones_like(_pu) / float(NUM_CLASSES)\n    log_C    = tf.math.log(tf.cast(NUM_CLASSES, tf.float32))\n    _H       = -tf.reduce_sum(_pu * tf.math.log(tf.clip_by_value(_pu,1e-8,1.0)), axis=-1, keepdims=True)\n    _W       = tf.clip_by_value(1.0 - _H/log_C, 0.0, 1.0)\n    _loss    = tf.reduce_mean(_W * tf.reduce_sum(tf.square(_dummy - _pu), axis=-1, keepdims=True))\n\nstem_layer = student.get_layer('stem_conv')\n_grads = _tape.gradient(_loss, stem_layer.trainable_variables)\n\nif any(g is not None for g in _grads):\n    print(\"✅ Gradient reaches stem_conv\")\nelse:\n    raise RuntimeError(\"❌ Gradient is None for stem_conv\")\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:20.322522Z","iopub.status.busy":"2026-05-22T14:20:20.322139Z","iopub.status.idle":"2026-05-22T14:20:23.749907Z","shell.execute_reply":"2026-05-22T14:20:23.748927Z"},"papermill":{"duration":3.436737,"end_time":"2026-05-22T14:20:23.751549+00:00","exception":false,"start_time":"2026-05-22T14:20:20.314812+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 11 — Two Separate Optimizers\n\n**v3:** Warmup and SSL use different LR schedules.  \nWarmup uses `LR_MAX_WARMUP=5e-5` (conservative — transformer+head fine-tuning).  \nSSL uses `LR_MAX_SSL=1e-4` (was 3e-4 — too aggressive for a converged backbone).\n","metadata":{"papermill":{"duration":0.006092,"end_time":"2026-05-22T14:20:23.764387+00:00","exception":false,"start_time":"2026-05-22T14:20:23.758295+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"STEPS_PER_EPOCH_OPT = len(labeled_flow_strong)\n\n# ── Warmup optimizer — very conservative LR ──────────────────────────────────\nwarmup_total = STEPS_PER_EPOCH_OPT * WARMUP_EPOCHS\nwarmup_lr_sched = WarmupCosineDecay(\n    lr_max=LR_MAX_WARMUP, lr_min=LR_MIN,\n    warmup_steps=STEPS_PER_EPOCH_OPT * 2,   # 2-epoch ramp\n    total_steps=warmup_total)\nwarmup_optimizer = tf.keras.optimizers.AdamW(\n    learning_rate=warmup_lr_sched, weight_decay=5e-4, clipnorm=1.0)\nwarmup_optimizer.build(_warmup_vars)\n\n# ── SSL optimizer — moderate LR for full backbone ────────────────────────────\nssl_total = STEPS_PER_EPOCH_OPT * SSL_EPOCHS\nssl_warmup = STEPS_PER_EPOCH_OPT * 3        # 3-epoch ramp into SSL\nssl_lr_sched = WarmupCosineDecay(\n    lr_max=LR_MAX_SSL, lr_min=LR_MIN,\n    warmup_steps=ssl_warmup,\n    total_steps=ssl_total)\nssl_optimizer = tf.keras.optimizers.AdamW(\n    learning_rate=ssl_lr_sched, weight_decay=5e-4, clipnorm=1.0)\nfor layer in student.layers:\n    layer.trainable = True\nssl_optimizer.build(student.trainable_variables)\n\nprint(f'Warmup optimizer: LR_MAX={LR_MAX_WARMUP}, vars={len(_warmup_vars)}')\nprint(f'SSL    optimizer: LR_MAX={LR_MAX_SSL},   vars={len(student.trainable_variables)}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:23.777856Z","iopub.status.busy":"2026-05-22T14:20:23.777500Z","iopub.status.idle":"2026-05-22T14:20:24.153454Z","shell.execute_reply":"2026-05-22T14:20:24.152506Z"},"papermill":{"duration":0.384711,"end_time":"2026-05-22T14:20:24.155115+00:00","exception":false,"start_time":"2026-05-22T14:20:23.770404+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 12 — ASR-SSL Loss Functions\n\n**v3:** Sharpening T=0.8 (softer than v2's T=0.5) prevents ATC collapse.\n","metadata":{"papermill":{"duration":0.006241,"end_time":"2026-05-22T14:20:24.167895+00:00","exception":false,"start_time":"2026-05-22T14:20:24.161654+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def sharpen(probs, T=SHARPEN_TEMP, eps=1e-8):\n    \"\"\"\n    Temperature sharpening. T=0.8 (v3) is softer than T=0.5 (v2).\n    T=0.5 made teacher nearly one-hot → ATC had nothing to learn from.\n    T=0.8 keeps some uncertainty while still sharpening pseudo-labels.\n    \"\"\"\n    sharp = tf.pow(tf.clip_by_value(probs, eps, 1.0), 1.0/T)\n    return sharp / (tf.reduce_sum(sharp, axis=-1, keepdims=True) + eps)\n\n\ndef eadw_consistency_loss(t_probs, s_probs, eps=1e-8):\n    \"\"\"W = 1 - H(p^T)/log(C). Applied after sharpening.\"\"\"\n    log_C   = tf.math.log(tf.cast(tf.shape(t_probs)[-1], tf.float32))\n    entropy = -tf.reduce_sum(t_probs * tf.math.log(t_probs + eps), axis=-1, keepdims=True)\n    W       = tf.clip_by_value(1.0 - entropy/log_C, 0.0, 1.0)\n    mse     = tf.reduce_sum(tf.square(t_probs - s_probs), axis=-1, keepdims=True)\n    return tf.reduce_mean(W * mse)\n\n\ndef atc_loss(attn_t, attn_s, eps=1e-8):\n    \"\"\"Symmetric KL between teacher/student transformer attention matrices.\"\"\"\n    B  = tf.shape(attn_t)[0]; flat = ATTN_SEQ_LEN * ATTN_SEQ_LEN\n    tf_= tf.reshape(attn_t, [B, -1, flat])\n    sf_= tf.reshape(attn_s, [B, -1, flat])\n    tn = tf_ / (tf.reduce_sum(tf_, axis=-1, keepdims=True) + eps)\n    sn = sf_ / (tf.reduce_sum(sf_, axis=-1, keepdims=True) + eps)\n    tn = tf.clip_by_value(tn, eps, 1.0); sn = tf.clip_by_value(sn, eps, 1.0)\n    kl_ts = tf.reduce_sum(tn * tf.math.log(tn/sn), axis=-1)\n    kl_st = tf.reduce_sum(sn * tf.math.log(sn/tn), axis=-1)\n    return tf.reduce_mean(0.5*(kl_ts+kl_st))\n\n\ndef adr_loss(attn_t, attn_s):\n    \"\"\"Frobenius distance penalty on attention drift.\"\"\"\n    diff = attn_t - attn_s\n    frob = tf.sqrt(tf.reduce_sum(tf.square(diff), axis=[-2,-1]) + 1e-8)\n    return tf.reduce_mean(frob)\n\n\n# v3: ramp over 20 epochs, max=0.5 (was 10 epochs, max=1.0 — too aggressive)\ndef ramp_up(current_epoch, ramp_epochs=20, w_max=W_CONS_MAX):\n    return w_max * min(1.0, current_epoch / max(ramp_epochs, 1))\n\n\nprint(f'Losses ready. SHARPEN_TEMP={SHARPEN_TEMP}, W_CONS_MAX={W_CONS_MAX}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:24.182233Z","iopub.status.busy":"2026-05-22T14:20:24.181430Z","iopub.status.idle":"2026-05-22T14:20:24.193490Z","shell.execute_reply":"2026-05-22T14:20:24.192805Z"},"papermill":{"duration":0.020584,"end_time":"2026-05-22T14:20:24.194785+00:00","exception":false,"start_time":"2026-05-22T14:20:24.174201+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 13 — ATP Helpers","metadata":{"papermill":{"duration":0.006484,"end_time":"2026-05-22T14:20:24.207638+00:00","exception":false,"start_time":"2026-05-22T14:20:24.201154+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def atp_feature_mask(seq, mask_frac=ATP_MASK_FRAC):\n    mask = tf.cast(tf.random.uniform(tf.shape(seq)) >= mask_frac, seq.dtype)\n    return seq * mask\n\ndef atp_token_shuffle(seq, shuffle_p=ATP_SHUFFLE_P):\n    B = tf.shape(seq)[0]\n    sw = tf.cast(tf.random.uniform([B]) < shuffle_p, seq.dtype)\n    sw3 = tf.reshape(sw, [B,1,1])\n    fine=seq[:,0:1,:]; coarse=seq[:,1:2,:]; ctx=seq[:,2:3,:]\n    nf = fine   + sw3*(coarse-fine)\n    nc = coarse + sw3*(fine-coarse)\n    return tf.concat([nf, nc, ctx], axis=1)\n\ndef apply_atp(seq):\n    seq = atp_feature_mask(seq); seq = atp_token_shuffle(seq); return seq\n\nprint(f'ATP: mask_frac={ATP_MASK_FRAC}, shuffle_p={ATP_SHUFFLE_P}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:24.221680Z","iopub.status.busy":"2026-05-22T14:20:24.221077Z","iopub.status.idle":"2026-05-22T14:20:24.227630Z","shell.execute_reply":"2026-05-22T14:20:24.226761Z"},"papermill":{"duration":0.014833,"end_time":"2026-05-22T14:20:24.228940+00:00","exception":false,"start_time":"2026-05-22T14:20:24.214107+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 14 — EMA Update + Validation","metadata":{"papermill":{"duration":0.006194,"end_time":"2026-05-22T14:20:24.241371+00:00","exception":false,"start_time":"2026-05-22T14:20:24.235177+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def ema_update(student_model, teacher_model, decay=EMA_DECAY):\n    for t_var, s_var in zip(teacher_model.variables, student_model.variables):\n        if t_var.trainable:\n            t_var.assign(decay*t_var + (1.0-decay)*s_var)\n\n@tf.function\ndef fast_predict(model, xb):\n    preds, _ = model(xb, training=False); return preds\n\ndef validate_teacher(model, flow):\n    all_probs, all_trues = [], []\n    flow.reset()\n    for _ in range(len(flow)):\n        xb, yb = next(flow)\n        all_probs.append(fast_predict(model, xb).numpy())\n        all_trues.append(yb)\n    probs = np.concatenate(all_probs); trues = np.concatenate(all_trues)\n    acc   = accuracy_score(np.argmax(trues,1), np.argmax(probs,1))\n    try:    mauc = roc_auc_score(trues, probs, average='macro', multi_class='ovr')\n    except: mauc = 0.0\n    return acc, mauc\n\nprint('ema_update and validate_teacher ready.')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:24.254915Z","iopub.status.busy":"2026-05-22T14:20:24.254540Z","iopub.status.idle":"2026-05-22T14:20:24.261483Z","shell.execute_reply":"2026-05-22T14:20:24.260734Z"},"papermill":{"duration":0.015463,"end_time":"2026-05-22T14:20:24.262986+00:00","exception":false,"start_time":"2026-05-22T14:20:24.247523+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 15 — Training Steps (v3 FINAL)\n\n**FIX 1:** `warmup_train_step` uses `_warmup_vars` (explicit list), not `[-20:]`.  \n**FIX 3:** Both teacher/student share same weak-aug view; ATP is token-level only.\n","metadata":{"papermill":{"duration":0.006309,"end_time":"2026-05-22T14:20:24.275620+00:00","exception":false,"start_time":"2026-05-22T14:20:24.269311+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"@tf.function\ndef warmup_train_step(x_lab, y_lab):\n    \"\"\"\n    v3 FIX 1: Uses _warmup_vars — the EXPLICITLY identified transformer+classifier\n    variables, not student.trainable_variables[-20:] (position-based slice).\n    The warmup optimizer runs at LR_MAX_WARMUP=5e-5 (very conservative).\n    \"\"\"\n    with tf.GradientTape() as tape:\n        s_probs, _ = student(x_lab, training=True)\n        loss = focal_loss_fn(y_lab, s_probs)\n    grads = tape.gradient(loss, _warmup_vars)\n    valid = [(g,v) for g,v in zip(grads,_warmup_vars) if g is not None]\n    warmup_optimizer.apply_gradients(valid)\n    return loss\n\n\ndef asr_ssl_train_step(x_lab, y_lab, x_unlab_weak, w_cons, w_atc, w_adr):\n    \"\"\"\n    v3 SSL step.\n    FIX 3: teacher and student BOTH receive x_unlab_weak (same view).\n            ATP is applied at token level only inside GradientTape.\n    v3 tuning: W_ATC=0.1, W_ADR=0.05, T=0.8 (softer sharpening).\n    \"\"\"\n    # ── Teacher: clean forward, no gradient ──────────────────────────────────\n    t_probs_raw, _ = teacher(x_unlab_weak, training=False)\n    t_seq    = teacher_seq_model(x_unlab_weak, training=False)\n    t_seq_pe = t_pos_enc(t_seq, training=False)\n    _, t_attn_w = t_tb(t_seq_pe, training=False, return_attention=True)\n\n    # v3: T=0.8 (softer than v2's T=0.5 which caused ATC collapse)\n    t_probs = sharpen(t_probs_raw, T=SHARPEN_TEMP)\n\n    # ── Student: GradientTape ─────────────────────────────────────────────────\n    with tf.GradientTape() as tape:\n        # Supervised loss\n        s_probs_lab, _ = student(x_lab, training=True)\n        l_sup = focal_loss_fn(y_lab, s_probs_lab)\n\n        # Same weak-aug view as teacher — ATP at token level only\n        s_seq    = student_seq_model(x_unlab_weak, training=True)\n        s_seq_pe = s_pos_enc(s_seq, training=True)\n        s_seq_atp = apply_atp(s_seq_pe)          # token perturbation only\n\n        s_enc, s_attn_w = s_tb(s_seq_atp, training=True, return_attention=True)\n        s_agg = tf.reduce_mean(s_enc, axis=1) + tf.reduce_max(s_enc, axis=1)\n\n        # Pre-identified classifier layers (FIX 2 — no layer-walking loop)\n        x_cls = s_d128(s_agg,  training=True)\n        x_cls = s_bn(x_cls,    training=True)\n        x_cls = s_drop1(x_cls, training=True)\n        x_cls = s_d64(x_cls,   training=True)\n        x_cls = s_drop2(x_cls, training=True)\n        s_probs_unlab = tf.nn.softmax(s_pred(x_cls, training=True), axis=-1)\n\n        l_cons = eadw_consistency_loss(t_probs, s_probs_unlab)\n        l_atc  = atc_loss(t_attn_w, s_attn_w)\n        l_adr  = adr_loss(t_attn_w, s_attn_w)\n\n        total = l_sup + w_cons*l_cons + w_atc*l_atc + w_adr*l_adr\n\n    grads = tape.gradient(total, student.trainable_variables)\n    valid = [(g,v) for g,v in zip(grads,student.trainable_variables) if g is not None]\n    ssl_optimizer.apply_gradients(valid)\n    return total, l_sup, l_cons, l_atc, l_adr\n\n\nprint('Train steps ready (v3).')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:24.289932Z","iopub.status.busy":"2026-05-22T14:20:24.289675Z","iopub.status.idle":"2026-05-22T14:20:24.299581Z","shell.execute_reply":"2026-05-22T14:20:24.298935Z"},"papermill":{"duration":0.018754,"end_time":"2026-05-22T14:20:24.301017+00:00","exception":false,"start_time":"2026-05-22T14:20:24.282263+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 16 — Training Loop","metadata":{"papermill":{"duration":0.006318,"end_time":"2026-05-22T14:20:24.313699+00:00","exception":false,"start_time":"2026-05-22T14:20:24.307381+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def run_asr_ssl_training(warmup_epochs=WARMUP_EPOCHS, ssl_epochs=SSL_EPOCHS,\n                          best_ckpt=CKPT_BEST):\n    history = {'loss':[],'l_sup':[],'l_cons':[],'l_atc':[],'l_adr':[],\n               'val_acc':[],'val_auc':[]}\n    best_val_auc = 0.0\n    unlabeled_iter = iter(unlabeled_flow_weak)\n\n    # ── Phase 2a: Warmup ─────────────────────────────────────────────────────\n    print('='*60)\n    print(f'  Phase 2a — Warmup ({warmup_epochs} epochs)')\n    print(f'  Training: transformer + classifier  LR={LR_MAX_WARMUP}')\n    print(f'  v3 FIX 1: explicit _warmup_vars list (not [-20:] slice)')\n    print('='*60)\n\n    for ep in range(warmup_epochs):\n        ep_losses = []\n        labeled_flow_strong.reset()\n        pbar = tqdm(range(STEPS_PER_EPOCH), desc=f'Warmup {ep+1}/{warmup_epochs}', leave=False)\n        for _ in pbar:\n            try:    xb, yb = next(labeled_flow_strong)\n            except StopIteration:\n                labeled_flow_strong.reset(); xb, yb = next(labeled_flow_strong)\n            loss = warmup_train_step(xb, yb)\n            ep_losses.append(float(loss))\n            pbar.set_postfix({'loss': f'{np.mean(ep_losses):.4f}'})\n\n        # v3 FIX 6: EMA update during warmup too (teacher tracks student improvements)\n        ema_update(student, teacher)\n        acc, auc_v = validate_teacher(teacher, val_flow)\n        history['loss'].append(np.mean(ep_losses))\n        history['l_sup'].append(np.mean(ep_losses))\n        for k in ['l_cons','l_atc','l_adr']: history[k].append(0.0)\n        history['val_acc'].append(acc); history['val_auc'].append(auc_v)\n        print(f'Warmup {ep+1:02d}/{warmup_epochs}  loss={np.mean(ep_losses):.4f}  '\n              f'val_acc={acc*100:.2f}%  val_auc={auc_v:.4f}')\n        if auc_v > best_val_auc:\n            best_val_auc = auc_v; teacher.save(best_ckpt)\n            print(f'  New best saved (AUC={best_val_auc:.4f})')\n\n    # ── Phase 2b: SSL ─────────────────────────────────────────────────────────\n    print('\\n'+'='*60)\n    print('  Phase 2b — ASR-SSL (EADW+ATP+ATC+ADR)')\n    print(f'  LR={LR_MAX_SSL}  W_CONS_MAX={W_CONS_MAX}  T={SHARPEN_TEMP}')\n    print(f'  W_ATC={W_ATC}  W_ADR={W_ADR}  ramp=20 epochs')\n    print('='*60)\n\n    for ep in range(ssl_epochs):\n        w_cons = ramp_up(ep, ramp_epochs=40, w_max=W_CONS_MAX)\n        ep_tot,ep_sup,ep_cons,ep_atc,ep_adr = [],[],[],[],[]\n        labeled_flow_strong.reset()\n        pbar = tqdm(range(STEPS_PER_EPOCH), desc=f'SSL {ep+1}/{ssl_epochs}', leave=False)\n\n        for _ in pbar:\n            try:    xl, yl = next(labeled_flow_strong)\n            except StopIteration:\n                labeled_flow_strong.reset(); xl, yl = next(labeled_flow_strong)\n            try:    xu, _ = next(unlabeled_iter)\n            except StopIteration:\n                unlabeled_iter = iter(unlabeled_flow_weak); xu, _ = next(unlabeled_iter)\n\n            bs = min(xl.shape[0], xu.shape[0])\n            tot,sup,cons,atc,adr = asr_ssl_train_step(\n                xl[:bs], yl[:bs], xu[:bs],\n                float(w_cons), float(W_ATC), float(W_ADR))\n            ep_tot.append(float(tot)); ep_sup.append(float(sup))\n            ep_cons.append(float(cons)); ep_atc.append(float(atc)); ep_adr.append(float(adr))\n            pbar.set_postfix({'sup':f'{float(sup):.3f}','cons':f'{float(cons):.3f}',\n                              'atc':f'{float(atc):.3f}','w':f'{w_cons:.2f}'})\n\n        ema_update(student, teacher)\n        acc, auc_v = validate_teacher(teacher, val_flow)\n        history['loss'].append(np.mean(ep_tot))\n        history['l_sup'].append(np.mean(ep_sup))\n        history['l_cons'].append(np.mean(ep_cons))\n        history['l_atc'].append(np.mean(ep_atc))\n        history['l_adr'].append(np.mean(ep_adr))\n 