ource":"## Cell 1 — Environment","metadata":{"papermill":{"duration":0.007063,"end_time":"2026-05-22T14:18:38.448591+00:00","exception":false,"start_time":"2026-05-22T14:18:38.441528+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"import os, sys, warnings, math, json, pickle\nwarnings.filterwarnings('ignore')\nimport tensorflow as tf\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nimport cv2\nfrom tqdm import tqdm\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import (\n    accuracy_score, classification_report, ConfusionMatrixDisplay,\n    roc_auc_score, roc_curve, auc, precision_score, recall_score, f1_score\n)\nfrom tensorflow.keras import backend as K\nfrom tensorflow.keras.layers import (\n    Conv2D, BatchNormalization, Activation, MaxPooling2D, AveragePooling2D,\n    Add, Multiply, GlobalAveragePooling2D, GlobalMaxPooling2D,\n    Dense, Input, Reshape, Concatenate,\n    Dropout, LayerNormalization, MultiHeadAttention\n)\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.regularizers import l2\n\ngpus = tf.config.list_physical_devices('GPU')\nfor gpu in gpus:\n    tf.config.experimental.set_memory_growth(gpu, True)\nprint(f'TensorFlow : {tf.__version__}')\nprint(f'GPUs       : {len(gpus)}')\nsns.set_style('whitegrid')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:18:38.461649Z","iopub.status.busy":"2026-05-22T14:18:38.461056Z","iopub.status.idle":"2026-05-22T14:19:06.871782Z","shell.execute_reply":"2026-05-22T14:19:06.870557Z"},"papermill":{"duration":28.419661,"end_time":"2026-05-22T14:19:06.873640+00:00","exception":false,"start_time":"2026-05-22T14:18:38.453979+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 2 — Global Configuration","metadata":{"papermill":{"duration":0.005612,"end_time":"2026-05-22T14:19:06.885334+00:00","exception":false,"start_time":"2026-05-22T14:19:06.879722+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"# ── Paths ────────────────────────────────────────────────────────────────────\nDATA_DIR   = '/kaggle/input/datasets/obulisainaren/retinal-oct-c8/RetinalOCT_Dataset/RetinalOCT_Dataset'\nPHASE1_MDL = '/kaggle/input/notebooks/ashrafulhossenakash/n1-10-ms-cbam-tra-seed-101/phase1_model.keras'\nCKPT_BEST  = '/kaggle/working/asr_ssl_teacher_best_v1.keras'\nWORKING    = '/kaggle/working'\n\n# ── Image / data ─────────────────────────────────────────────────────────────\nIMG_SIZE    = (224, 224)\nBATCH_SIZE  = 16\nNUM_CLASSES = 8\nSEED        = 101\nD_MODEL     = 64          # MUST match N1\n\n# ── Training schedule ─────────────────────────────────────────────────────────\nEMA_DECAY     = 0.99\nWARMUP_EPOCHS = 10        # v3: 5→10 to fully recover val baseline before SSL\nSSL_EPOCHS    = 60\n\n# v3: lower LR — pre-trained backbone needs gentle updates\nLR_MAX_WARMUP = 5e-5      # warmup LR (very conservative — head adaptation only)\nLR_MAX_SSL    = 1e-4      # SSL LR  (was 3e-4 — too aggressive for converged model)\nLR_MIN        = 1e-7\n\n# ── SSL loss weights ──────────────────────────────────────────────────────────\n# v3: W_CONS_MAX 1.0→0.5 — cons=0.51 in v2 was destabilising the backbone\nW_CONS_MAX = 0.5\nW_ATC      = 0.15          # v3: reduced 0.2→0.1 (ATC was collapsing to near-0)\nW_ADR      = 0.08         # v3: reduced 0.1→0.05\n\nLABEL_FRAC = 0.10\n\n# ── ATP ───────────────────────────────────────────────────────────────────────\nATP_MASK_FRAC = 0.20\nATP_SHUFFLE_P = 0.20\n\n# ── Attention ────────────────────────────────────────────────────────────────\nATTN_NUM_HEADS = 2\nATTN_SEQ_LEN   = 3\n\n# ── v3: Softer sharpening T=0.8 (was 0.5 — too aggressive, caused ATC collapse)\nSHARPEN_TEMP = 0.8\n\nCLASSES = sorted(['NORMAL','AMD','CNV','CSR','DME','DR','DRUSEN','MH'])\nprint('Classes:', CLASSES)\n_CW_LIST = [1.0] * NUM_CLASSES\nfor i, c in enumerate(CLASSES):\n    if c in ('NORMAL', 'DRUSEN'):\n        _CW_LIST[i] = 1.5\n_DEFAULT_CLASS_WEIGHTS = tf.constant(_CW_LIST, dtype=tf.float32)\nprint(f'Class weights: { {CLASSES[i]: _CW_LIST[i] for i in range(NUM_CLASSES)} }')\ntf.random.set_seed(SEED); np.random.seed(SEED)\nprint('Config ready.')\nprint(f'  LR_MAX_WARMUP={LR_MAX_WARMUP}, LR_MAX_SSL={LR_MAX_SSL}')\nprint(f'  W_CONS_MAX={W_CONS_MAX}, W_ATC={W_ATC}, W_ADR={W_ADR}')\nprint(f'  SHARPEN_TEMP={SHARPEN_TEMP}, WARMUP_EPOCHS={WARMUP_EPOCHS}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:19:06.897972Z","iopub.status.busy":"2026-05-22T14:19:06.897432Z","iopub.status.idle":"2026-05-22T14:19:07.045634Z","shell.execute_reply":"2026-05-22T14:19:07.044486Z"},"papermill":{"duration":0.156491,"end_time":"2026-05-22T14:19:07.047492+00:00","exception":false,"start_time":"2026-05-22T14:19:06.891001+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 3 — Custom Layers (identical to N1)","metadata":{"papermill":{"duration":0.005547,"end_time":"2026-05-22T14:19:07.058978+00:00","exception":false,"start_time":"2026-05-22T14:19:07.053431+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"class ReduceMeanAxis1(tf.keras.layers.Layer):\n    def call(self, x): return tf.reduce_mean(x, axis=1)\n    def compute_output_shape(self, s): return (s[0], s[2])\n\nclass ReduceMaxAxis1(tf.keras.layers.Layer):\n    def call(self, x): return tf.reduce_max(x, axis=1)\n    def compute_output_shape(self, s): return (s[0], s[2])\n\nclass ChannelMean(tf.keras.layers.Layer):\n    def call(self, x): return tf.reduce_mean(x, axis=-1, keepdims=True)\n    def compute_output_shape(self, s): return tuple(s[:-1]) + (1,)\n\nclass ChannelMax(tf.keras.layers.Layer):\n    def call(self, x): return tf.reduce_max(x, axis=-1, keepdims=True)\n    def compute_output_shape(self, s): return tuple(s[:-1]) + (1,)\n\nclass FlattenSpatialAttn(tf.keras.layers.Layer):\n    def call(self, x):\n        B = tf.shape(x)[0]; return tf.reshape(x, [B, -1])\n    def compute_output_shape(self, s):\n        return (s[0], s[1] * s[2]) if len(s) >= 4 else s\n\nprint('Custom layers defined.')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:19:07.072507Z","iopub.status.busy":"2026-05-22T14:19:07.071814Z","iopub.status.idle":"2026-05-22T14:19:07.079738Z","shell.execute_reply":"2026-05-22T14:19:07.078986Z"},"papermill":{"duration":0.016162,"end_time":"2026-05-22T14:19:07.081299+00:00","exception":false,"start_time":"2026-05-22T14:19:07.065137+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4 — Transformer + WarmupCosineDecay + focal_loss_fn","metadata":{"papermill":{"duration":0.005493,"end_time":"2026-05-22T14:19:07.092509+00:00","exception":false,"start_time":"2026-05-22T14:19:07.087016+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"class SinusoidalPositionalEncoding(tf.keras.layers.Layer):\n    def __init__(self, max_len=3, d_model=64, **kwargs):\n        super().__init__(**kwargs)\n        self.max_len = max_len; self.d_model = d_model\n        pe = np.zeros((max_len, d_model), dtype=np.float32)\n        for pos in range(max_len):\n            for i in range(0, d_model, 2):\n                angle = pos / (10000.0 ** (2 * i / d_model))\n                pe[pos, i] = math.sin(angle)\n                if i + 1 < d_model: pe[pos, i+1] = math.cos(angle)\n        self.pe = tf.constant(pe[np.newaxis], dtype=tf.float32)\n    def call(self, x): return x + self.pe[:, :tf.shape(x)[1], :]\n    def get_config(self):\n        cfg = super().get_config(); cfg.update({'max_len':self.max_len,'d_model':self.d_model}); return cfg\n\n\nclass TransformerEncoderBlock(tf.keras.layers.Layer):\n    def __init__(self, d_model=64, num_heads=2, dropout_rate=0.2, l2_reg=2e-4, **kwargs):\n        super().__init__(**kwargs)\n        self.d_model=d_model; self.num_heads=num_heads\n        self.dropout_rate=dropout_rate; self.l2_reg=l2_reg\n        key_dim = d_model // num_heads\n        self.ln1    = LayerNormalization(epsilon=1e-6)\n        self.mhsa   = MultiHeadAttention(num_heads=num_heads, key_dim=key_dim, dropout=dropout_rate)\n        self.drop1  = Dropout(dropout_rate)\n        self.ln2    = LayerNormalization(epsilon=1e-6)\n        self.ffn_w1 = Dense(4*d_model, activation='gelu', kernel_regularizer=l2(l2_reg))\n        self.ffn_w2 = Dense(d_model, kernel_regularizer=l2(l2_reg))\n        self.drop2  = Dropout(dropout_rate)\n\n    def call(self, x, training=False, return_attention=False):\n        x_ln = self.ln1(x)\n        if return_attention:\n            attn_out, attn_w = self.mhsa(x_ln, x_ln, training=training, return_attention_scores=True)\n        else:\n            attn_out = self.mhsa(x_ln, x_ln, training=training); attn_w = None\n        attn_out = self.drop1(attn_out, training=training); x = x + attn_out\n        x_ln = self.ln2(x)\n        ffn  = self.ffn_w2(self.ffn_w1(x_ln))\n        ffn  = self.drop2(ffn, training=training); out = x + ffn\n        return (out, attn_w) if return_attention else out\n\n    def get_config(self):\n        cfg = super().get_config()\n        cfg.update({'d_model':self.d_model,'num_heads':self.num_heads,\n                    'dropout_rate':self.dropout_rate,'l2_reg':self.l2_reg}); return cfg\n\n\ndef build_transformer_head(seq_input, d_model=64, num_heads=2,\n                            dropout_rate=0.2, l2_reg=2e-4, name_prefix=''):\n    x = SinusoidalPositionalEncoding(max_len=3, d_model=d_model,\n                                     name=f'{name_prefix}pos_enc')(seq_input)\n    x = TransformerEncoderBlock(d_model=d_model, num_heads=num_heads,\n                                dropout_rate=dropout_rate, l2_reg=l2_reg,\n                                name=f'{name_prefix}transformer_block')(x)\n    return Add()([ReduceMeanAxis1()(x), ReduceMaxAxis1()(x)])\n\n\nclass WarmupCosineDecay(tf.keras.optimizers.schedules.LearningRateSchedule):\n    def __init__(self, lr_max, lr_min, warmup_steps, total_steps, **kwargs):\n        super().__init__(**kwargs)\n        self.lr_max=float(lr_max); self.lr_min=float(lr_min)\n        self.warmup_steps=float(warmup_steps); self.total_steps=float(total_steps)\n    def __call__(self, step):\n        step = tf.cast(step, tf.float32)\n        warmup = self.lr_max * (step / self.warmup_steps)\n        cs = tf.maximum(step - self.warmup_steps, 0.0)\n        ct = tf.maximum(self.total_steps - self.warmup_steps, 1.0)\n        cosine = self.lr_min + 0.5*(self.lr_max-self.lr_min)*(1.0+tf.cos(math.pi*cs/ct))\n        return tf.where(step < self.warmup_steps, warmup, cosine)\n    def get_config(self):\n        return {'lr_max':self.lr_max,'lr_min':self.lr_min,\n                'warmup_steps':self.warmup_steps,'total_steps':self.total_steps}\n\n\ndef focal_loss_fn(y_true, y_pred, gamma=2.0, label_smoothing=0.1, eps=1e-8):\n    num_cls  = tf.cast(tf.shape(y_true)[-1], tf.float32)\n    y_smooth = y_true*(1.0-label_smoothing) + label_smoothing/num_cls\n    y_pred   = tf.clip_by_value(y_pred, eps, 1.0-eps)\n    ce       = -y_smooth * tf.math.log(y_pred)\n    fw       = tf.pow(1.0-y_pred, gamma)\n    return tf.reduce_mean(tf.reduce_sum(_DEFAULT_CLASS_WEIGHTS*fw*ce, axis=-1))\n\n\nCUSTOM_OBJECTS = {\n    'SinusoidalPositionalEncoding': SinusoidalPositionalEncoding,\n    'TransformerEncoderBlock':      TransformerEncoderBlock,\n    'ReduceMeanAxis1': ReduceMeanAxis1, 'ReduceMaxAxis1': ReduceMaxAxis1,\n    'ChannelMean': ChannelMean, 'ChannelMax': ChannelMax,\n    'FlattenSpatialAttn': FlattenSpatialAttn,\n    'WarmupCosineDecay': WarmupCosineDecay, 'focal_loss_fn': focal_loss_fn,\n}\nprint('Cell 4 ready.')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:19:07.105303Z","iopub.status.busy":"2026-05-22T14:19:07.105092Z","iopub.status.idle":"2026-05-22T14:19:07.121719Z","shell.execute_reply":"2026-05-22T14:19:07.120772Z"},"papermill":{"duration":0.025215,"end_time":"2026-05-22T14:19:07.123279+00:00","exception":false,"start_time":"2026-05-22T14:19:07.098064+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5 — Dataset Split","metadata":{"papermill":{"duration":0.005867,"end_time":"2026-05-22T14:19:07.134855+00:00","exception":false,"start_time":"2026-05-22T14:19:07.128988+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"BASE   = DATA_DIR\nSPLITS = ['train', 'test', 'val']\nfile_p, label_list = [], []\nfor cls in CLASSES:\n    for split in SPLITS:\n        d = os.path.join(BASE, split, cls)\n        if not os.path.exists(d): continue\n        for name in os.listdir(d):\n            file_p.append(os.path.join(d, name)); label_list.append(cls)\n\ndf = pd.DataFrame({'filepaths': file_p, 'labels': label_list})\nprint(f'Total images: {len(df):,}')\n\ntrain_val_df, test_df = train_test_split(\n    df, test_size=0.20, random_state=SEED, stratify=df['labels'])\ntrain_val_df, val_df = train_test_split(\n    train_val_df, test_size=0.15, random_state=SEED, stratify=train_val_df['labels'])\nlabeled_df, unlabeled_df = train_test_split(\n    train_val_df, train_size=LABEL_FRAC, random_state=SEED, stratify=train_val_df['labels'])\n\nunlabeled_df_hidden = unlabeled_df[['filepaths']].copy()\nunlabeled_df_hidden['labels'] = 'UNKNOWN'\nprint(f'Test      : {len(test_df):,}')\nprint(f'Val       : {len(val_df):,}')\nprint(f'Labeled   : {len(labeled_df):,} ({LABEL_FRAC*100:.0f}%)')\nprint(f'Unlabeled : {len(unlabeled_df):,} ({(1-LABEL_FRAC)*100:.0f}%)')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:19:07.148636Z","iopub.status.busy":"2026-05-22T14:19:07.147976Z","iopub.status.idle":"2026-05-22T14:19:07.807246Z","shell.execute_reply":"2026-05-22T14:19:07.806267Z"},"papermill":{"duration":0.667831,"end_time":"2026-05-22T14:19:07.808774+00:00","exception":false,"start_time":"2026-05-22T14:19:07.140943+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 6 — Preprocessing & Augmentation","metadata":{"papermill":{"duration":0.005657,"end_time":"2026-05-22T14:19:07.820399+00:00","exception":false,"start_time":"2026-05-22T14:19:07.814742+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"from tensorflow.keras.preprocessing.image import ImageDataGenerator\n\ndef enhance_image(image):\n    img_uint8 = np.clip(image, 0, 255).astype(np.uint8)\n    lab = cv2.cvtColor(img_uint8, cv2.COLOR_RGB2LAB)\n    l, a, b = cv2.split(lab)\n    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8,8))\n    l = clahe.apply(l)\n    enhanced = cv2.cvtColor(cv2.merge([l, a, b]), cv2.COLOR_LAB2RGB)\n    gaussian  = cv2.GaussianBlur(enhanced, (5,5), 1.0)\n    return cv2.addWeighted(enhanced, 1.5, gaussian, -0.5, 0).astype(np.float32)\n\ndef cutout(img_norm, mask_sizes=(16,32), p=0.5):\n    if np.random.random() >= p: return img_norm\n    img = img_norm.copy(); h, w = img.shape[:2]\n    ms = int(np.random.choice(mask_sizes))\n    cx = np.random.randint(ms//2, max(ms//2+1, w-ms//2+1))\n    cy = np.random.randint(ms//2, max(ms//2+1, h-ms//2+1))\n    x1=max(cx-ms//2,0); x2=min(cx+ms//2,w)\n    y1=max(cy-ms//2,0); y2=min(cy+ms//2,h)\n    img[y1:y2,x1:x2,:] = 0.0; return img\n\ndef enhance_with_cutout(image):\n    e = enhance_image(image)/255.0; e = cutout(e)\n    return (e*255.0).astype(np.float32)\n\nlabeled_gen   = ImageDataGenerator(rescale=1./255, preprocessing_function=enhance_with_cutout,\n    rotation_range=15, width_shift_range=0.15, height_shift_range=0.15,\n    shear_range=0.08, zoom_range=0.15, horizontal_flip=True, fill_mode='constant', cval=0.0)\nunlabeled_gen = ImageDataGenerator(rescale=1./255, preprocessing_function=enhance_image,\n    rotation_range=7, width_shift_range=0.05, height_shift_range=0.05,\n    horizontal_flip=True, fill_mode='constant', cval=0.0)\neval_gen      = ImageDataGenerator(rescale=1./255, preprocessing_function=enhance_image)\n\ndef make_flow(gen, df_, shuffle=True, labels='categorical'):\n    return gen.flow_from_dataframe(df_, x_col='filepaths', y_col='labels',\n        target_size=IMG_SIZE, color_mode='rgb', class_mode=labels,\n        batch_size=BATCH_SIZE, shuffle=shuffle)\n\nlabeled_flow_strong = make_flow(labeled_gen,   labeled_df,          shuffle=True)\nval_flow            = make_flow(eval_gen,       val_df,              shuffle=False)\ntest_flow           = make_flow(eval_gen,       test_df,             shuffle=False)\nunlabeled_flow_weak = make_flow(unlabeled_gen,  unlabeled_df_hidden, shuffle=True)\nunlabeled_flow_weak.reset()\n\nSTEPS_PER_EPOCH = len(labeled_flow_strong)\nprint(f'Class indices : {labeled_flow_strong.class_indices}')\nprint(f'Steps/epoch   : {STEPS_PER_EPOCH}')\nprint(f'Unlabeled batches: {len(unlabeled_flow_weak)}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:19:07.833460Z","iopub.status.busy":"2026-05-22T14:19:07.833138Z","iopub.status.idle":"2026-05-22T14:20:10.517920Z","shell.execute_reply":"2026-05-22T14:20:10.517125Z"},"papermill":{"duration":62.698696,"end_time":"2026-05-22T14:20:10.525185+00:00","exception":false,"start_time":"2026-05-22T14:19:07.826489+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 7 — Architecture Blocks","metadata":{"papermill":{"duration":0.005636,"end_time":"2026-05-22T14:20:10.536677+00:00","exception":false,"start_time":"2026-05-22T14:20:10.531041+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def se_block(X, ratio=8):\n    f = X.shape[-1]\n    se = GlobalAveragePooling2D()(X)\n    se = Dense(max(1,f//ratio), activation='relu', kernel_regularizer=l2(1e-4))(se)\n    se = Dense(f, activation='sigmoid', kernel_regularizer=l2(1e-4))(se)\n    return Multiply()([X, Reshape((1,1,f))(se)])\n\ndef cbam_block(X, ratio=8, return_attn=False):\n    f = X.shape[-1]\n    avg_c = GlobalAveragePooling2D()(X); max_c = GlobalMaxPooling2D()(X)\n    d1 = Dense(max(1,f//ratio), activation='relu', kernel_regularizer=l2(1e-4))\n    d2 = Dense(f, kernel_regularizer=l2(1e-4))\n    ch_att = Activation('sigmoid')(d2(d1(avg_c)) + d2(d1(max_c)))\n    X = Multiply()([X, Reshape((1,1,f))(ch_att)])\n    avg_s = ChannelMean()(X); max_s = ChannelMax()(X)\n    sp_att = Conv2D(1,(7,7),padding='same',activation='sigmoid',\n                   kernel_regularizer=l2(1e-4))(Concatenate(axis=-1)([avg_s,max_s]))\n    out = Multiply()([X, sp_att])\n    return (out, sp_att) if return_attn else out\n\ndef identity_block(X, f):\n    skip = X\n    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n    X = BatchNormalization()(X); X = Activation('relu')(X)\n    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n    X = BatchNormalization()(X); X = se_block(X)\n    return Activation('relu')(Add()([X, skip]))\n\ndef conv_block(X, f):\n    skip = X\n    X = Conv2D(f,(3,3),strides=(2,2),padding='same',kernel_regularizer=l2(1e-4))(X)\n    X = BatchNormalization()(X); X = Activation('relu')(X)\n    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n    X = BatchNormalization()(X); X = se_block(X)\n    skip = Conv2D(f,(1,1),strides=(2,2),kernel_regularizer=l2(1e-4))(skip)\n    return Activation('relu')(Add()([X, skip]))\n\nprint('Architecture blocks defined.')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:10.549808Z","iopub.status.busy":"2026-05-22T14:20:10.549231Z","iopub.status.idle":"2026-05-22T14:20:10.559767Z","shell.execute_reply":"2026-05-22T14:20:10.559131Z"},"papermill":{"duration":0.018642,"end_time":"2026-05-22T14:20:10.561186+00:00","exception":false,"start_time":"2026-05-22T14:20:10.542544+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 8 — Model Builder","metadata":{"papermill":{"duration":0.005708,"end_time":"2026-05-22T14:20:10.572666+00:00","exception":false,"start_time":"2026-05-22T14:20:10.566958+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"def build_ms_cbam_transformer(input_shape=(224,224,3), num_classes=8, name='model'):\n    inp  = Input(shape=input_shape, name='input_image')\n    stem = Conv2D(32,(7,7),strides=(2,2),padding='same',\n                  kernel_regularizer=l2(1e-4),name='stem_conv')(inp)\n    stem = BatchNormalization()(stem); stem = Activation('relu')(stem)\n    stem = MaxPooling2D((3,3),strides=(2,2),padding='same')(stem)\n\n    A = conv_block(stem,32); A = identity_block(A,32); A = identity_block(A,32); A = cbam_block(A)\n    A = conv_block(A,64);   A = identity_block(A,64);  A = identity_block(A,64);  A = cbam_block(A)\n    A = conv_block(A,128);  A = identity_block(A,128)\n    A_out, A_sp = cbam_block(A, ratio=16, return_attn=True)\n    attn_flat   = FlattenSpatialAttn(name='attn_flat')(A_sp)\n    A_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(\n             Add()([GlobalAveragePooling2D()(A_out), GlobalMaxPooling2D()(A_out)]))\n\n    B = conv_block(stem,32); B = identity_block(B,32); B = cbam_block(B)\n    B = conv_block(B,64);   B = identity_block(B,64);  B = cbam_block(B)\n    B = MaxPooling2D((3,3),padding='same')(B)\n    B_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(\n             Add()([GlobalAveragePooling2D()(B), GlobalMaxPooling2D()(B)]))\n\n    C2 = GlobalAveragePooling2D()(Conv2D(32,(1,1),activation='relu')(\n         AveragePooling2D((2,2),strides=(2,2),padding='same')(stem)))\n    C4 = GlobalAveragePooling2D()(Conv2D(32,(1,1),activation='relu')(\n         AveragePooling2D((4,4),strides=(4,4),padding='same')(stem)))\n    C_feat = Dense(D_MODEL,activation='relu',kernel_regularizer=l2(1e-4))(Concatenate()([C2,C4]))\n\n    seq = Concatenate(axis=1,name='anatomical_sequence')([\n        Reshape((1,D_MODEL))(A_feat), Reshape((1,D_MODEL))(B_feat), Reshape((1,D_MODEL))(C_feat)])\n\n    agg = build_transformer_head(seq, d_model=D_MODEL, num_heads=2,\n                                 dropout_rate=0.2, l2_reg=2e-4, name_prefix=f'{name}_')\n\n    out = Dense(128,activation='relu',kernel_regularizer=l2(1e-4))(agg)\n    out = BatchNormalization()(out); out = Dropout(0.4)(out)\n    out = Dense(64, activation='relu',kernel_regularizer=l2(1e-4))(out)\n    out = Dropout(0.3)(out)\n    predictions = Dense(num_classes, activation='softmax', name='predictions')(out)\n    return Model(inputs=inp, outputs=[predictions, attn_flat], name=name)\n\nstudent = build_ms_cbam_transformer(name='student')\nteacher = build_ms_cbam_transformer(name='teacher')\n_d = tf.zeros((1,224,224,3))\nprint(f'Student params: {student.count_params():,}')\nprint(f'Output shapes : preds={student(_d)[0].shape}, attn={student(_d)[1].shape}')\n","metadata":{"execution":{"iopub.execute_input":"2026-05-22T14:20:10.585365Z","iopub.status.busy":"2026-05-22T14:20:10.585144Z","iopub.status.idle":"2026-05-22T14:20:16.126605Z","shell.execute_reply":"2026-05-22T14:20:16.125664Z"},"papermill":{"duration":5.549874,"end_time":"2026-05-22T14:20:16.128303+00:00","exception":false,"start_time":"2026-05-22T14:20:10.578429+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 9 — Transfer N1 Weights","metadata":{"papermill":{"duration":0.007096,"end_time":"2026-05-22T14:20:16.142142+00:00","exception":false,"start_time":"2026-05-22T14:20:16.135046+00:00","status":"completed"},"tags":[]}},{"cell_type":"code","source":"phase1 = tf.keras.models.load_model(PHASE1_MDL, custom_objects=CUSTOM_OBJECTS)\nprint(f'N1 loaded: {phase1.count_params():,} params')\n\nn1_layers = [l for l in phase1.layers  if l.get_weights()]\nn2_layers = [l for l in student.layers if l.get_weights()]\ntransferred = 0\nfor n1_l, n2_l in zip(n1_layers, n2_layers):\n    if [w.shape for w in n1_l.get_weights()] == [w.shape for w in n2_l.get_weights()]:\n        n2_l.set_weight