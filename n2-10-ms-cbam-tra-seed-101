    "# ── Sequence submodels ───────────────────────────────────────────────────────\n",
    "def build_seq_submodel(model):\n",
    "    seq_layer = model.get_layer('anatomical_sequence')\n",
    "    return tf.keras.Model(inputs=model.inputs, outputs=seq_layer.output,\n",
    "                          name=model.name + '_seq')\n",
    "\n",
    "student_seq_model = build_seq_submodel(student)\n",
    "teacher_seq_model = build_seq_submodel(teacher)\n",
    "\n",
    "# ── Transformer layers ────────────────────────────────────────────────────────\n",
    "def get_transformer_layers(model):\n",
    "    pe, tb = None, None\n",
    "    for l in model.layers:\n",
    "        if 'pos_enc'           in l.name: pe = l\n",
    "        if 'transformer_block' in l.name: tb = l\n",
    "    assert pe and tb; return pe, tb\n",
    "\n",
    "s_pos_enc, s_tb = get_transformer_layers(student)\n",
    "t_pos_enc, t_tb = get_transformer_layers(teacher)\n",
    "print(f'Student: pos_enc={s_pos_enc.name}, tb={s_tb.name}')\n",
    "\n",
    "# ── Classifier layers — identified by name/type, NOT by slice ────────────────\n",
    "def get_classifier_layers(model):\n",
    "    layers = list(model.layers)\n",
    "    # Dense(128) — last one (backbone has no Dense(128))\n",
    "    d128 = [l for l in layers if isinstance(l,Dense) and l.units==128][-1]\n",
    "    idx128 = layers.index(d128)\n",
    "    # BN after d128\n",
    "    bn    = next(l for l in layers[idx128:] if isinstance(l,BatchNormalization))\n",
    "    # Dropouts after d128\n",
    "    drops = [l for l in layers[idx128:] if isinstance(l,Dropout)]\n",
    "    assert len(drops) >= 2\n",
    "    drop1, drop2 = drops[0], drops[1]\n",
    "    # Dense(64) after d128 (not 'predictions')\n",
    "    d64   = next(l for l in layers[idx128:] if isinstance(l,Dense)\n",
    "                 and l.units==64 and l.name!='predictions')\n",
    "    pred  = model.get_layer('predictions')\n",
    "    return d128, bn, drop1, d64, drop2, pred\n",
    "\n",
    "s_d128, s_bn, s_drop1, s_d64, s_drop2, s_pred = get_classifier_layers(student)\n",
    "print('Classifier layers:')\n",
    "for name, layer in [('Dense(128)',s_d128),('BN',s_bn),('Drop1',s_drop1),\n",
    "                    ('Dense(64)',s_d64),('Drop2',s_drop2),('pred',s_pred)]:\n",
    "    print(f'  {name:12s}: {layer.name}')\n",
    "\n",
    "# ── v3 FIX 1: Warmup vars — explicit list, NOT a position slice ───────────────\n",
    "# Include: pos_enc, transformer_block, Dense(128), BN, Dense(64), predictions\n",
    "_warmup_layers = [s_pos_enc, s_tb, s_d128, s_bn, s_drop1, s_d64, s_drop2, s_pred]\n",
    "_warmup_vars   = []\n",
    "for layer in _warmup_layers:\n",
    "    _warmup_vars.extend(layer.trainable_variables)\n",
    "print(f'\\nWarmup trainable vars: {len(_warmup_vars)} '\n",
    "      f'(transformer+classifier, explicit list)')\n",
    "\n",
    "# ── Gradient connectivity check ───────────────────────────────────────────────\n",
    "print('\\nGradient connectivity check...')\n",
    "_xu, _ = next(iter(unlabeled_flow_weak))\n",
    "with tf.GradientTape() as _tape:\n",
    "    _seq    = student_seq_model(_xu[:4], training=True)\n",
    "    _seq_pe = s_pos_enc(_seq, training=True)\n",
    "    # ATP\n",
    "    _B = tf.shape(_seq_pe)[0]\n",
    "    _mask = tf.cast(tf.random.uniform(tf.shape(_seq_pe)) >= ATP_MASK_FRAC, _seq_pe.dtype)\n",
    "    _seq_atp = _seq_pe * _mask\n",
    "    _enc, _  = s_tb(_seq_atp, training=True, return_attention=True)\n",
    "    _agg     = tf.reduce_mean(_enc, axis=1) + tf.reduce_max(_enc, axis=1)\n",
    "    _x       = s_d128(_agg,  training=True)\n",
    "    _x       = s_bn(_x,      training=True)\n",
    "    _x       = s_drop1(_x,   training=True)\n",
    "    _x       = s_d64(_x,     training=True)\n",
    "    _x       = s_drop2(_x,   training=True)\n",
    "    _pu      = tf.nn.softmax(s_pred(_x), axis=-1)\n",
    "    _dummy   = tf.ones_like(_pu) / float(NUM_CLASSES)\n",
    "    log_C    = tf.math.log(tf.cast(NUM_CLASSES, tf.float32))\n",
    "    _H       = -tf.reduce_sum(_pu * tf.math.log(tf.clip_by_value(_pu,1e-8,1.0)), axis=-1, keepdims=True)\n",
    "    _W       = tf.clip_by_value(1.0 - _H/log_C, 0.0, 1.0)\n",
    "    _loss    = tf.reduce_mean(_W * tf.reduce_sum(tf.square(_dummy - _pu), axis=-1, keepdims=True))\n",
    "\n",
    "stem_layer = student.get_layer('stem_conv')\n",
    "_grads = _tape.gradient(_loss, stem_layer.trainable_variables)\n",
    "\n",
    "if any(g is not None for g in _grads):\n",
    "    print(\"✅ Gradient reaches stem_conv\")\n",
    "else:\n",
