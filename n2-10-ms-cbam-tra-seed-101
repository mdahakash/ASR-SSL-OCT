    "best_teacher = tf.keras.models.load_model(CKPT_BEST, custom_objects=CUSTOM_OBJECTS)\n",
    "print(f'Best teacher: {best_teacher.count_params():,} params')\n",
    "\n",
    "def predict_flow(model, flow):\n",
    "    all_probs, all_ohe = [], []\n",
    "    flow.reset()\n",
    "    for _ in range(len(flow)):\n",
    "        xb, yb = next(flow)\n",
    "        p, _ = model(xb, training=False)\n",
    "        all_probs.append(p.numpy()); all_ohe.append(yb)\n",
    "    return np.concatenate(all_probs), np.concatenate(all_ohe)\n",
    "\n",
    "test_probs, test_ohe = predict_flow(best_teacher, test_flow)\n",
    "test_preds = np.argmax(test_probs,1); test_trues = np.argmax(test_ohe,1)\n",
    "lmap  = {v:k for k,v in test_flow.class_indices.items()}\n",
    "tnames = [lmap[i] for i in test_trues]; pnames = [lmap[i] for i in test_preds]\n",
    "\n",
    "metrics = {\n",
    "    'accuracy'    : accuracy_score(test_trues, test_preds),\n",
    "    'precision'   : precision_score(tnames,pnames,average='macro',zero_division=0),\n",
