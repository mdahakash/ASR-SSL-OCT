    "def sharpen(probs, T=SHARPEN_TEMP, eps=1e-8):\n",
    "    \"\"\"\n",
    "    Temperature sharpening. T=0.8 (v3) is softer than T=0.5 (v2).\n",
    "    T=0.5 made teacher nearly one-hot → ATC had nothing to learn from.\n",
    "    T=0.8 keeps some uncertainty while still sharpening pseudo-labels.\n",
    "    \"\"\"\n",
    "    sharp = tf.pow(tf.clip_by_value(probs, eps, 1.0), 1.0/T)\n",
    "    return sharp / (tf.reduce_sum(sharp, axis=-1, keepdims=True) + eps)\n",
    "\n",
    "\n",
    "def eadw_consistency_loss(t_probs, s_probs, eps=1e-8):\n",
    "    \"\"\"W = 1 - H(p^T)/log(C). Applied after sharpening.\"\"\"\n",
    "    log_C   = tf.math.log(tf.cast(tf.shape(t_probs)[-1], tf.float32))\n",
    "    entropy = -tf.reduce_sum(t_probs * tf.math.log(t_probs + eps), axis=-1, keepdims=True)\n",
    "    W       = tf.clip_by_value(1.0 - entropy/log_C, 0.0, 1.0)\n",
    "    mse     = tf.reduce_sum(tf.square(t_probs - s_probs), axis=-1, keepdims=True)\n",
    "    return tf.reduce_mean(W * mse)\n",
    "\n",
    "\n",
    "def atc_loss(attn_t, attn_s, eps=1e-8):\n",
    "    \"\"\"Symmetric KL between teacher/student transformer attention matrices.\"\"\"\n",
    "    B  = tf.shape(attn_t)[0]; flat = ATTN_SEQ_LEN * ATTN_SEQ_LEN\n",
    "    tf_= tf.reshape(attn_t, [B, -1, flat])\n",
    "    sf_= tf.reshape(attn_s, [B, -1, flat])\n",
    "    tn = tf_ / (tf.reduce_sum(tf_, axis=-1, keepdims=True) + eps)\n",
    "    sn = sf_ / (tf.reduce_sum(sf_, axis=-1, keepdims=True) + eps)\n",
    "    tn = tf.clip_by_value(tn, eps, 1.0); sn = tf.clip_by_value(sn, eps, 1.0)\n",
    "    kl_ts = tf.reduce_sum(tn * tf.math.log(tn/sn), axis=-1)\n",
    "    kl_st = tf.reduce_sum(sn * tf.math.log(sn/tn), axis=-1)\n",
    "    return tf.reduce_mean(0.5*(kl_ts+kl_st))\n",
    "\n",
    "\n",
    "def adr_loss(attn_t, attn_s):\n",
    "    \"\"\"Frobenius distance penalty on attention drift.\"\"\"\n",
    "    diff = attn_t - attn_s\n",
    "    frob = tf.sqrt(tf.reduce_sum(tf.square(diff), axis=[-2,-1]) + 1e-8)\n",
    "    return tf.reduce_mean(frob)\n",
    "\n",
    "\n",
    "# v3: ramp over 20 epochs, max=0.5 (was 10 epochs, max=1.0 — too aggressive)\n",
    "def ramp_up(current_epoch, ramp_epochs=20, w_max=W_CONS_MAX):\n",
    "    return w_max * min(1.0, current_epoch / max(ramp_epochs, 1))\n",
    "\n",
    "\n",
    "print(f'Losses ready. SHARPEN_TEMP={SHARPEN_TEMP}, W_CONS_MAX={W_CONS_MAX}')\n"
