    "def se_block(X, ratio=8):\n",
    "    f = X.shape[-1]\n",
    "    se = GlobalAveragePooling2D()(X)\n",
    "    se = Dense(max(1,f//ratio), activation='relu', kernel_regularizer=l2(1e-4))(se)\n",
    "    se = Dense(f, activation='sigmoid', kernel_regularizer=l2(1e-4))(se)\n",
    "    return Multiply()([X, Reshape((1,1,f))(se)])\n",
    "\n",
    "def cbam_block(X, ratio=8, return_attn=False):\n",
    "    f = X.shape[-1]\n",
    "    avg_c = GlobalAveragePooling2D()(X); max_c = GlobalMaxPooling2D()(X)\n",
    "    d1 = Dense(max(1,f//ratio), activation='relu', kernel_regularizer=l2(1e-4))\n",
    "    d2 = Dense(f, kernel_regularizer=l2(1e-4))\n",
    "    ch_att = Activation('sigmoid')(d2(d1(avg_c)) + d2(d1(max_c)))\n",
    "    X = Multiply()([X, Reshape((1,1,f))(ch_att)])\n",
    "    avg_s = ChannelMean()(X); max_s = ChannelMax()(X)\n",
    "    sp_att = Conv2D(1,(7,7),padding='same',activation='sigmoid',\n",
    "                   kernel_regularizer=l2(1e-4))(Concatenate(axis=-1)([avg_s,max_s]))\n",
    "    out = Multiply()([X, sp_att])\n",
    "    return (out, sp_att) if return_attn else out\n",
    "\n",
    "def identity_block(X, f):\n",
    "    skip = X\n",
    "    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n",
    "    X = BatchNormalization()(X); X = Activation('relu')(X)\n",
    "    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n",
    "    X = BatchNormalization()(X); X = se_block(X)\n",
    "    return Activation('relu')(Add()([X, skip]))\n",
    "\n",
    "def conv_block(X, f):\n",
    "    skip = X\n",
    "    X = Conv2D(f,(3,3),strides=(2,2),padding='same',kernel_regularizer=l2(1e-4))(X)\n",
    "    X = BatchNormalization()(X); X = Activation('relu')(X)\n",
    "    X = Conv2D(f,(3,3),padding='same',kernel_regularizer=l2(1e-4))(X)\n",
    "    X = BatchNormalization()(X); X = se_block(X)\n",
    "    skip = Conv2D(f,(1,1),strides=(2,2),kernel_regularizer=l2(1e-4))(skip)\n",
    "    return Activation('relu')(Add()([X, skip]))\n",
    "\n",
    "print('Architecture blocks defined.')\n"
