    "    v3 tuning: W_ATC=0.1, W_ADR=0.05, T=0.8 (softer sharpening).\n",
    "    \"\"\"\n",
    "    # ── Teacher: clean forward, no gradient ──────────────────────────────────\n",
    "    t_probs_raw, _ = teacher(x_unlab_weak, training=False)\n",
    "    t_seq    = teacher_seq_model(x_unlab_weak, training=False)\n",
