","iopub.status.idle":"2026-07-18T16:42:16.993843Z","shell.execute_reply.started":"2026-07-18T16:42:16.869164Z","shell.execute_reply":"2026-07-18T16:42:16.993236Z"}},"outputs":[{"name":"stdout","text":"DataParallel across 2 GPUs (Tesla T4)\n\nStudent / Teacher parameters : 1,069,614\nOptimizer : AdamW  lr_max=0.0003  wd=5e-4  clip=1.0\nSchedule  : linear warmup 8ep → cosine decay\nAMP       : True  (device=cuda)\nTracker   : Φ⁽⁰⁾ = I ✓   n_unlabeled=13,872   PL memory = 111 KB\n","output_type":"stream"}],"execution_count":18},{"id":"ba9d1b5d-cd0a-4894-87ef-3049749d5b27","cell_type":"code","source":"def train_one_epoch_pass(\n    student, teacher,\n    labeled_loader, unlabeled_loader,\n    optimizer, scaler,\n    focal_loss_fn, gtc_loss_fn,\n    tracker,\n    epoch, total_epochs, device,\n    mu=MU,\n    lambda_st=LAMBDA_ST,\n    lambda_div=LAMBDA_DIV,\n    max_grad_norm=MAX_GRAD_NORM,\n):\n    \"\"\"\n    One epoch of PASS semi-supervised training.\n\n    Preserved from base v5, byte-for-byte in behaviour:\n      OOM-safe μ-chunked unsupervised passes · AMP · running metric counters (no\n      list accumulation) · reservoir AUC · periodic empty_cache/gc · EMA teacher.\n\n    New:\n      · directional debiasing of the teacher logits          (PASS_USE_DEBIAS)\n      · ordinal-entropy acceptance gate + soft target        (PASS_USE_GATE)\n      · asymmetric under-grading cost on L_sup and L_u       (PASS_USE_ASYM_COST)\n      · Grassmannian token consistency, now OPTIONAL         (USE_GRASSMANNIAN_MODULE)\n      · Φ bookkeeping every chunk, in EVERY run mode incl. R0\n\n    With all four flags False this is EXACTLY the base notebook's FixMatch branch\n    minus the Grassmannian terms — i.e. a faithful R0 baseline, not a broken variant.\n    \"\"\"\n    student.train()\n    teacher.train()                    # BN in train mode for proper running stats\n\n    use_debias = PASS_USE_DEBIAS\n    use_gate   = PASS_USE_GATE\n    use_asym   = PASS_USE_ASYM_COST\n    use_grass  = USE_GRASSMANNIAN_MODULE\n\n    lambda_grass = (grassmannian_weight_schedule(\n        epoch, lambda_max=LAMBDA_GRASS_MAX, warmup_epochs=GRASS_WARMUP)\n        if use_grass else 0.0)\n    ema_alpha = ema_momentum_schedule(epoch, total_epochs, alpha_base=EMA_BASE)\n    lam_d_now = lambda_d_schedule(epoch) if use_debias else 0.0\n\n    total_loss_sum = sup_loss_sum = grass_loss_sum = stf_loss_sum = div_loss_sum = 0.0\n    pl_loss_sum    = 0.0\n    correct = total = 0\n    n_accept = n_total_ul = 0\n    distal_sum = 0.0\n\n    _AUC_RESERVOIR_MAX = 5000\n    _auc_probs_buf, _auc_targets_buf, _auc_buf_count = [], [], 0\n\n    unlabeled_iter = iter(unlabeled_loader)\n\n    bar = tqdm(labeled_loader,\n               desc=f'Epoch {epoch:3d}/{total_epochs} [{RUN_NAME}]',\n               leave=False, dynamic_ncols=True, colour='green')\n\n    for step, (xb_l, yb_l) in enumerate(bar):\n        xb_l = xb_l.to(device, non_blocking=True)\n        yb_l = yb_l.to(device, non_blocking=True)\n\n        optimizer.zero_grad(set_to_none=True)\n\n        # ═══════════════════════════════════════════════════════════════════\n        # STEP 1 — supervised forward (student only)\n        # ═══════════════════════════════════════════════════════════════════\n        with autocast(device_type=DEVICE_TYPE, enabled=USE_AMP):\n            logits_l = student(xb_l, return_tokens=False)          # (b_l, C)\n\n            if use_asym:\n                # per-sample focal loss × asymmetric under-grading multiplier.\n                # w is DETACHED — it is a cost weight, not a differentiable path.\n                per_sample_l = focal_loss_fn(logits_l, yb_l, reduction='none')   # (b_l,)\n                with torch.no_grad():\n                    w_l = asym_sample_weight(\n                        yb_l, F.softmax(logits_l.float().detach(), dim=-1))\n                L_sup = (per_sample_l * w_l).mean()\n                del per_sample_l, w_l\n            else:\n                L_sup = focal_loss_fn(logits_l, yb_l)              # ← base behaviour\n\n        scaler.scale(L_sup).backward()\n\n        with torch.no_grad():\n            preds_l  = logits_l.detach().argmax(1)\n            correct += (preds_l == yb_l).sum().item()\n            total   += xb_l.size(0)\n            if _auc_buf_count < _AUC_RESERVOIR_MAX:\n                n_take = min(xb_l.size(0), _AUC_RESERVOIR_MAX - _auc_buf_count)\n                _auc_probs_buf.append(\n                    F.softmax(logits_l.detach()[:n_take], dim=-1).cpu().float().numpy())\n                _auc_targets_buf.append(yb_l[:n_take].cpu().numpy())\n                _auc_buf_count += n_take\n\n        del logits_l, preds_l, xb_l, yb_l\n\n        # ═══════════════════════════════════════════════════════════════════\n        # STEP 2 — fetch unlabeled batch  (now a 3-tuple: weak, strong, idx)\n        # ═══════════════════════════════════════════════════════════════════\n        try:\n            xb_u_weak, xb_u_strong, idx_u = next(unlabeled_iter)\n        except StopIteration:\n            del unlabeled_iter          # release the old iterator promptly\n            unlabeled_iter = iter(unlabeled_loader)\n            xb_u_weak, xb_u_strong, idx_u = next(unlabeled_iter)\n\n        # ═══════════════════════════════════════════════════════════════════\n        # STEP 3 — OOM-safe μ-chunked unsupervised passes\n        # ═══════════════════════════════════════════════════════════════════\n        chunk_size = xb_u_weak.size(0) // mu\n        chunk_grass = chunk_stf = chunk_div = chunk_pl = 0.0\n\n        for k in range(mu):\n            s = k * chunk_size\n            e = s + chunk_size\n\n            weak_k   = xb_u_weak[s:e].to(device, non_blocking=True)\n            strong_k = xb_u_strong[s:e].to(device, non_blocking=True)\n            idx_k    = idx_u[s:e]         # CPU LongTensor — moved to device in the tracker\n\n            # ───────────────────────────────────────────────────────────────\n            # TEACHER — ONE forward pass. Tokens are captured here, inside this\n            # same no_grad block, WHILE weak_k IS STILL ALIVE.\n            #\n            # ██ BUG FIX #1 — VARIABLE LIFETIME ██\n            # A prior draft ran the teacher for logits, immediately did\n            # `del weak_k`, and then later — inside the optional Grassmannian\n            # branch — called `teacher(weak_k, return_tokens=True)`. That is a\n            # NameError, but it fires ONLY when USE_GRASSMANNIAN_MODULE=True, so\n            # it passes every default run and detonates on the one ablation you'd\n            # run last. Fix: request the tokens in the SAME forward, cache M_t_k\n            # here, and place the single `del weak_k` AFTER this block — after\n            # the tensor's genuine last use. Nothing needed by a later branch is\n            # ever freed before that branch runs. (Also strictly cheaper: one\n            # teacher forward, not two.)\n            # ───────────────────────────────────────────────────────────────\n            with torch.no_grad():\n                with autocast(device_type=DEVICE_TYPE, enabled=USE_AMP):\n                    if use_grass:\n                        teacher_logits_k, M_t_k = teacher(weak_k, return_tokens=True)\n                    else:\n                        teacher_logits_k = teacher(weak_k, return_tokens=False)\n                        M_t_k = None\n                if M_t_k is not None:\n                    M_t_k = M_t_k.detach()          # captured while weak_k is valid\n\n                # ── teacher distribution, optionally debiased ──────────────\n                # .float(): fp16 softmax saturates to 0/1 and destroys the gate.\n                z_t = teacher_logits_k.float()\n                if use_debias:\n                    z_t = directional_debias(z_t, tracker.Phi, lam_d_now,\n                                             eps=PASS_EPS, one_sided=PASS_ONE_SIDED)\n                q_t = F.softmax(z_t / PASS_TEACHER_TEMP, dim=-1)          # (b,K) = q̃\n\n                # ── acceptance ────────────────────────────────────────────\n                if use_gate:\n                    accept_k, pl_k, conf_k, distal_k, soft_k = ordinal_entropy_gate(\n                        q_t, tracker.neighbor_mask, PASS_TAU_LO, PASS_BETA)\n                else:\n                    # R0 / R1 fallback — FAITHFUL FixMatch: hard τ=0.95, hard label.\n                    conf_k, pl_k = q_t.max(dim=1)\n                    accept_k = conf_k >= TAU\n                    distal_k = torch.zeros_like(conf_k)\n                    soft_k   = None                  # hard CE path below\n\n                mask_k = accept_k.float()            # (b,)\n                n_accept   += int(mask_k.sum().item())\n                n_total_ul += mask_k.numel()\n                distal_sum += float(distal_k.sum().item())\n\n                # ── Φ bookkeeping — ALWAYS, in EVERY run mode including R0.\n                # Φ's evolution under plain FixMatch IS the diagnostic (Fig. 1/2).\n                # Vectorized; idx_k is moved to the tracker's device inside.\n                tl_k = unlabeled_true_idx[idx_k] if PASS_LOG_PURITY else None\n                tracker.record_chunk(idx_k, pl_k, accept_k, true_labels=tl_k)\n\n            # weak_k has now served BOTH of its uses: the teacher logits AND the\n            # cached tokens for the optional branch. Only now is it safe to free.\n            # ██ This `del` is deliberately placed AFTER the no_grad block. ██\n            del weak_k, teacher_logits_k, z_t, q_t, conf_k, distal_k, accept_k\n\n            # ───────────────────────────────────────────────────────────────\n            # STUDENT — strong-augmented forward + losses\n            # ───────────────────────────────────────────────────────────────\n            with autocast(device_type=DEVICE_TYPE, enabled=USE_AMP):\n                if use_grass:\n                    student_logits_k, M_s_k = student(strong_k, return_tokens=True)\n                    # M_t_k is the tensor cached above — the branch that used to NameError.\n                    L_grass_k, L_stf_k, L_div_k = gtc_loss_fn(M_s_k, M_t_k)\n                else:\n                    student_logits_k = student(strong_k, return_tokens=False)\n                    M_s_k = None\n                    _zero = torch.zeros((), device=device)\n                    L_grass_k = L_stf_k = L_div_k = _zero\n\n                # ── pseudo-label loss ─────────────────────────────────────\n                if mask_k.sum() > 0:\n                    if use_gate:\n                        # soft CE against the neighbourhood-restricted target\n                        logp     = F.log_softmax(student_logits_k.float(), dim=-1)\n                        L_pl_raw = -(soft_k * logp).sum(dim=1)          # (b,)\n                        del logp\n                    else:\n                        L_pl_raw = F.cross_entropy(student_logits_k, pl_k,\n                                                   reduction='none')    # (b,)  base\n                    if use_asym:\n                        with torch.no_grad():\n                            w_u = asym_sample_weight(\n                                pl_k, F.softmax(student_logits_k.float().detach(), dim=-1))\n                        L_pl_raw = L_pl_raw * w_u\n                        del w_u\n                    L_pl_k = (L_pl_raw * mask_k).sum() / (mask_k.sum() + 1e-8)\n                    del L_pl_raw\n                else:\n                    L_pl_k = torch.zeros((), device=device)\n\n                L_unsup_k = (\n                    lambda_grass * L_grass_k +\n                    lambda_st    * L_stf_k   +\n                    lambda_div   * L_div_k   +\n                    LAMBDA_PL    * L_pl_k\n                ) / float(mu)\n\n            del strong_k, M_t_k, pl_k, mask_k, soft_k, student_logits_k\n\n            # Guard: with the Grassmannian module OFF and zero accepted pseudo-labels\n            # this chunk, L_unsup_k is a constant with no graph. backward() would\n            # raise \"element 0 of tensors does not require grad\". Base v5 never hit\n            # this because L_grass always carried a gradient.\n            if L_unsup_k.requires_grad:\n                scaler.scale(L_unsup_k).backward()\n\n            chunk_grass += float(L_grass_k)\n            chunk_stf   += float(L_stf_k)\n            chunk_div   += float(L_div_k)\n            chunk_pl    += float(L_pl_k)\n\n            del M_s_k, L_grass_k, L_stf_k, L_div_k, L_pl_k, L_unsup_k\n\n        del xb_u_weak, xb_u_strong, idx_u\n\n        chunk_grass /= mu\n        chunk_stf   /= mu\n        chunk_div   /= mu\n        chunk_pl    /= mu\n\n        # ═══════════════════════════════════════════════════════════════════\n        # STEP 4 — grad clip + optimiser step\n        # ═══════════════════════════════════════════════════════════════════\n        scaler.unscale_(optimizer)\n        torch.nn.utils.clip_grad_norm_(student.parameters(), max_grad_norm)\n        scaler.step(optimizer)\n        scaler.update()\n\n        # ═══════════════════════════════════════════════════════════════════\n        # STEP 5 — EMA teacher update\n        # ═══════════════════════════════════════════════════════════════════\n        ema_update(student, teacher, ema_alpha)\n\n        L_sup_val = L_sup.item()\n        del L_sup\n\n        total_loss_sum += (L_sup_val + lambda_grass * chunk_grass +\n                           lambda_st * chunk_stf + lambda_div * chunk_div +\n                           LAMBDA_PL * chunk_pl)\n        sup_loss_sum   += L_sup_val\n        grass_loss_sum += chunk_grass\n        stf_loss_sum   += chunk_stf\n        div_loss_sum   += chunk_div\n        pl_loss_sum    += chunk_pl\n\n        bar.set_postfix(\n            loss=f'{total_loss_sum/(step+1):.4f}',\n            acc=f'{correct/total:.3f}',\n            Lpl=f'{chunk_pl:.3f}',\n            acc_r=f'{n_accept/max(n_total_ul,1):.2f}',\n            dist=f'{distal_sum/max(n_total_ul,1):.3f}',\n        )\n\n        if (step + 1) % _CUDA_CACHE_CLEAR_EVERY == 0:\n            torch.cuda.empty_cache()\n        if (step + 1) % _GC_COLLECT_EVERY == 0:\n            gc.collect()\n\n    # ── epoch-level AUC from the reservoir ──────────────────────────────────\n    n_steps = step + 1\n    train_auc = 0.5\n    if _auc_buf_count > 0:\n        _all_probs   = np.concatenate(_auc_probs_buf,   axis=0)\n        _all_targets = np.concatenate(_auc_targets_buf, axis=0)\n        if len(np.unique(_all_targets)) >= 2:\n            ohe = np.zeros((len(_all_targets), NUM_CLASSES))\n            ohe[np.arange(len(_all_targets)), _all_targets] = 1\n            try:\n                train_auc = roc_auc_score(ohe, _all_probs, average='macro', multi_class='ovr')\n            except ValueError:\n                train_auc = 0.5\n        del _all_probs, _all_targets, _auc_probs_buf, _auc_targets_buf\n\n    del unlabeled_iter\n    gc.collect()\n    torch.cuda.empty_cache()\n\n    return {\n        'train_loss':   total_loss_sum / n_steps,\n        'L_sup':        sup_loss_sum   / n_steps,\n        'L_grass':      grass_loss_sum / n_steps,\n        'L_stiefel':    stf_loss_sum   / n_steps,\n        'L_div':        div_loss_sum   / n_steps,\n        'L_pl':         pl_loss_sum    / n_steps,\n        'train_acc':    correct / max(total, 1),\n        'train_auc':    train_auc,\n        'lambda_grass': lambda_grass,\n        'lambda_d':     lam_d_now,\n        'ema_alpha':    ema_alpha,\n        'mask_ratio':   n_accept / max(n_total_ul, 1),\n        'mean_distal':  distal_sum / max(n_total_ul, 1),\n    }\n\nprint('train_one_epoch_pass defined.')\nprint('  bug #1 weak_k lifetime : single teacher forward, tokens cached inside the')\nprint('                           no_grad block, `del weak_k` AFTER it  ✓')\nprint('  bug #2 vectorization   : bincount transitions + masked gather/scatter gate  ✓')\nprint('  bug #3 device          : idx moved to tracker.device + asserted  ✓')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:16.994725Z","iopub.execute_input":"2026-07-18T16:42:16.995029Z","iopub.status.idle":"2026-07-18T16:42:17.0417Z","shell.execute_reply.started":"2026-07-18T16:42:16.995002Z","shell.execute_reply":"2026-07-18T16:42:17.041105Z"}},"outputs":[{"name":"stdout","text":"train_one_epoch_pass defined.\n  bug #1 weak_k lifetime : single teacher forward, tokens cached inside the\n                           no_grad block, `del weak_k` AFTER it  ✓\n  bug #2 vectorization   : bincount transitions + masked gather/scatter gate  ✓\n  bug #3 device          : idx moved to tracker.device + asserted  ✓\n","output_type":"stream"}],"execution_count":19},{"id":"bbfe9163-822b-47a8-8936-97dd1be09013","cell_type":"code","source":"@torch.no_grad()\ndef evaluate(model, loader, criterion, device,\n             epoch=0, total_epochs=0, split='Val', tta=False):\n    \"\"\"Standard evaluation loop. Optional 5-pass TTA. UNCHANGED from base v5.\"\"\"\n    model.eval()\n    total_loss, correct, total = 0.0, 0, 0\n    all_probs, all_targets = [], []\n\n    bar = tqdm(loader, desc=f'Epoch {epoch:3d}/{total_epochs} [{split:>4}]',\n               leave=False, dynamic_ncols=True, colour='blue')\n\n    for xb, yb in bar:\n        xb = xb.to(device, non_blocking=True)\n        yb = yb.to(device, non_blocking=True)\n\n        with autocast(device_type=DEVICE_TYPE, enabled=USE_AMP):\n            if tta:\n                p1 = F.softmax(model(xb), dim=-1)\n                p2 = F.softmax(model(torch.flip(xb, dims=[-1])), dim=-1)\n                p3 = F.softmax(model(torch.flip(xb, dims=[-2])), dim=-1)\n                p4 = F.softmax(model(TF.rotate(xb, angle=10)),  dim=-1)\n                p5 = F.softmax(model(TF.rotate(xb, angle=-10)), dim=-1)\n                probs  = (p1 + p2 + p3 + p4 + p5) / 5.0\n                logits = model(xb)\n                loss   = criterion(logits, yb)\n                del p1, p2, p3, p4, p5, logits\n            else:\n                logits = model(xb)\n                loss   = criterion(logits, yb)\n                probs  = F.softmax(logits, dim=-1)\n\n        all_probs.append(probs.cpu().float().numpy())\n        all_targets.append(yb.cpu().numpy())\n\n        bs          = xb.size(0)\n        total_loss += loss.item() * bs\n        correct    += (probs.argmax(1) == yb).sum().item()\n        total      += bs\n\n        del xb, yb, probs, loss\n        bar.set_postfix(loss=f'{total_loss/total:.4f}', acc=f'{correct/total:.3f}')\n\n    all_probs   = np.concatenate(all_probs,   axis=0)\n    all_targets = np.concatenate(all_targets, axis=0)\n    torch.cuda.empty_cache()\n    return total_loss / total, correct / total, all_probs, all_targets\n\n\ndef compute_metrics(probs, targets, split_name='Test'):\n    preds   = probs.argmax(axis=1)\n    p_names = [IDX2CLASS[i] for i in preds]\n    t_names = [IDX2CLASS[i] for i in targets]\n    ohe = np.zeros((len(targets), NUM_CLASSES))\n    ohe[np.arange(len(targets)), targets] = 1\n    metrics = {\n        'accuracy':     accuracy_score(t_names, p_names),\n        'precision':    precision_score(t_names, p_names, average='macro', zero_division=0),\n        'recall':       recall_score(t_names, p_names, average='macro', zero_division=0),\n        'f1_macro':     f1_score(t_names, p_names, average='macro', zero_division=0),\n        'auc_macro':    roc_auc_score(ohe, probs, average='macro', multi_class='ovr'),\n        'auc_weighted': roc_auc_score(ohe, probs, average='weighted', multi_class='ovr'),\n    }\n    print(f\"\\n{'─'*50}  {split_name}\")\n    for k, v in metrics.items():\n        print(f'  {k:18s}: {v:.4f}')\n    return metrics, preds, p_names, t_names\n\nprint('Evaluation and metrics defined.')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:17.042673Z","iopub.execute_input":"2026-07-18T16:42:17.042989Z","iopub.status.idle":"2026-07-18T16:42:17.075466Z","shell.execute_reply.started":"2026-07-18T16