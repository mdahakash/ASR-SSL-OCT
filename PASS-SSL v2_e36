                                      labeled_df['labels'].tolist(),\n                                      CLASS2IDX, transform=eval_transform, img_size=IMG_SIZE)\n    _val_ds  = OCTDatasetDisk(val_df['filepaths'].tolist(), val_df['labels'].tolist(),\n                              CLASS2IDX, transform=eval_transform, img_size=IMG_SIZE)\n    _test_ds = OCTDatasetDisk(test_df['filepaths'].tolist(), test_df['labels'].tolist(),\n                              CLASS2IDX, transform=eval_transform, img_size=IMG_SIZE)\n\nif UNLABELED_ONDISK or not CACHE_DATASETS:\n    _unlabeled_ds = DualAugDatasetDisk(\n        unlabeled_df['filepaths'].tolist(),\n        weak_transform=weak_transform, strong_transform=strong_transform,\n        img_size=IMG_SIZE)\n    _pin_ul = False\nelse:\n    _unlabeled_ds = DualAugDatasetCached(\n        unlabeled_cache, weak_transform=weak_transform,\n        strong_transform=strong_transform)\n    _pin_ul = True\n\nassert len(_unlabeled_ds) == N_UNLABELED, 'unlabeled dataset / index-map length mismatch'\n\n\ndef _make_loader(ds, bs, shuffle, pin, drop_last=False):\n    # persistent_workers=True keeps the same worker processes (and their shm\n    # segments) alive across epochs instead of respawning them on every\n    # iter(loader) call — train_one_epoch_pass re-iters the unlabeled loader\n    # every epoch (and mid-epoch on StopIteration), and repeated spawn/teardown\n    # of num_workers processes was exhausting /dev/shm over ~12 epochs.\n    return DataLoader(ds, batch_size=bs, shuffle=shuffle, num_workers=_WORKERS,\n                      pin_memory=pin, drop_last=drop_last,\n                      persistent_workers=(_WORKERS > 0))\n\n\nlabeled_loader      = _make_loader(_labeled_ds,      BATCH_SIZE,      True,  True,  True)\nlabeled_eval_loader = _make_loader(_labeled_eval_ds, 64,              False, True,  False)\nunlabeled_loader    = _make_loader(_unlabeled_ds,    MU * BATCH_SIZE, True,  _pin_ul, True)\nval_loader          = _make_loader(_val_ds,          64,              False, True,  False)\ntest_loader         = _make_loader(_test_ds,         64,              False, True,  False)\n\nprint(f'Labeled   batches/epoch : {len(labeled_loader)}')\nprint(f'Labeled-eval batches    : {len(labeled_eval_loader)}   (Φ \"C\" estimator)')\nprint(f'Unlabeled batches/epoch : {len(unlabeled_loader)}')\nprint(f'Val / Test batches      : {len(val_loader)} / {len(test_loader)}')\n\nxb_l, yb_l       = next(iter(labeled_loader))\nxb_w, xb_s, ix_u = next(iter(unlabeled_loader))     # ← 3-tuple now\nprint(f'\\n✅ Labeled batch    : {tuple(xb_l.shape)}, labels {tuple(yb_l.shape)}')\nprint(f'✅ Unlabeled weak   : {tuple(xb_w.shape)}')\nprint(f'✅ Unlabeled strong : {tuple(xb_s.shape)}')\nprint(f'✅ Unlabeled idx    : {tuple(ix_u.shape)}  dtype={ix_u.dtype}  '\n      f'device={ix_u.device}  range=[{ix_u.min().item()}, {ix_u.max().item()}]')\ndel xb_l, yb_l, xb_w, xb_s, ix_u\ngc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:09.392058Z","iopub.execute_input":"2026-07-18T16:42:09.392292Z","iopub.status.idle":"2026-07-18T16:42:15.750056Z","shell.execute_reply.started":"2026-07-18T16:42:09.39227Z","shell.execute_reply":"2026-07-18T16:42:15.748653Z"}},"outputs":[{"name":"stdout","text":"Labeled   batches/epoch : 76\nLabeled-eval batches    : 39   (Φ \"C\" estimator)\nUnlabeled batches/epoch : 108\nVal / Test batches      : 45 / 75\n\n✅ Labeled batch    : (32, 3, 224, 224), labels (32,)\n✅ Unlabeled weak   : (128, 3, 224, 224)\n✅ Unlabeled strong : (128, 3, 224, 224)\n✅ Unlabeled idx    : (128,)  dtype=torch.int64  device=cpu  range=[106, 13343]\n","output_type":"stream"},{"execution_count":12,"output_type":"execute_result","data":{"text/plain":"0"},"metadata":{}}],"execution_count":12},{"id":"d1c39beb-30b2-44ae-9865-8d34e2627933","cell_type":"markdown","source":"## PASS core\n\nEverything below is new. Four pieces:\n\n1. **`ConfusionFlowTracker`** — maintains Φ. `Φ⁽⁰⁾ = I`, literally. No AREDS, no clinical\n   prior, nothing but the identity matrix. This single line is what licenses the claim that\n   the AMD progression chain was *discovered* rather than encoded.\n2. **`directional_debias`** — `z̃ = z − λ_d·ReLU(log(K·u))`. The ReLU is one-sided and\n   mandatory (Cell 17 proves why).\n3. **`ordinal_entropy_gate`** — accept iff `q̃_ĵ ≥ τ_lo` **and** `distal ≤ β`. Neighbourhoods\n   come from Φ itself. Accepted samples train on a neighbourhood-restricted soft target.\n4. **`asym_sample_weight`** — the only place any clinical knowledge enters the method, and\n   only one bit of it: *which end of the Φ-discovered chain is clinically worse.*","metadata":{}},{"id":"689ff7d5-2035-4e2f-b802-1be7d9cca790","cell_type":"code","source":"# ═════════════════════════════════════════════════════════════════════════════\n#  PASS CORE — confusion-flow Φ · directional debiasing · ordinal gate · asym cost\n# ═════════════════════════════════════════════════════════════════════════════\n\n# ── Ordinal ranks on the AMD progression spectrum ────────────────────────────\n# THE ONLY CLINICAL KNOWLEDGE IN THE ENTIRE METHOD, and it is one bit: the\n# DIRECTION of the chain. The chain *structure* (which classes are adjacent) is\n# discovered by Φ; AREDS supplies only which end is \"worse\". Off-spectrum classes\n# get rank −1 and weight 1 — they are never touched.\nSPECTRUM_ORDER = ['NORMAL', 'DRUSEN', 'CNV']            # rank 0 → 1 → 2\nRANK = torch.full((NUM_CLASSES,), -1, dtype=torch.long)\nfor _r, _c in enumerate(SPECTRUM_ORDER):\n    RANK[CLASS2IDX[_c]] = _r\nRANK = RANK.to(DEVICE)\n\n\ndef build_asym_cost_matrix(rank, gamma=PASS_GAMMA, beta_u=PASS_BETA_U):\n    \"\"\"\n    W[y][c] = (1 + |r_y − r_c|)^γ · (1 + β_u · 1[r_c < r_y])\n\n    r_c < r_y  ⇔  the model called it LESS severe than it is  ⇔  UNDER-grading\n    (missing early AMD), which is the clinically expensive direction.\n    Off-spectrum pairs (either rank == −1) → 1.0.  Diagonal → 1.0 always.\n    β_u = 0 recovers a symmetric ordinal cost (the ablation).\n    \"\"\"\n    K = rank.numel()\n    r = rank.view(-1, 1).float()                       # (K,1)  r_y\n    c = rank.view(1, -1).float()                       # (1,K)  r_c\n    on_spectrum = (r >= 0) & (c >= 0)\n    dist  = (r - c).abs()\n    under = (c < r).float()\n    W = (1.0 + dist) ** gamma * (1.0 + beta_u * under)\n    return torch.where(on_spectrum, W, torch.ones_like(W)).to(rank.device)\n\n\nW_ASYM = build_asym_cost_matrix(RANK)\n\n\n# ═════════════════════════════════════════════════════════════════════════════\nclass ConfusionFlowTracker:\n    \"\"\"\n    Online estimator of the confusion-flow matrix Φ ∈ R^{K×K}.\n\n        Φ⁽⁰⁾ = I                                     ← literal identity. No prior.\n        C[i][j] = mean teacher softmax prob of j among TRUE-label-i LABELED samples\n        T[i][j] = frac. of accepted PLs that were i last epoch and are j this epoch\n        Φ̃      = α·C + (1−α)·T                       α = 0.5\n        Φ      ← m·Φ_prev + (1−m)·Φ̃                  m = 0.9\n\n    Updated every epoch in EVERY run mode, including R0 — Φ's evolution under\n    plain FixMatch is itself the diagnostic (Figures 1 & 2).\n    \"\"\"\n\n    def __init__(self, num_classes, n_unlabeled,\n                 alpha=PASS_PHI_ALPHA, momentum=PASS_PHI_MOMENTUM,\n                 topk=PASS_PHI_TOPK, device=DEVICE):\n        self.K        = num_classes\n        self.device   = device\n        self.alpha    = alpha\n        self.momentum = momentum\n        self.topk     = topk\n\n        # ── Φ⁽⁰⁾ = I.  Literal.  Assert it in Cell 16. ──────────────────────\n        self.Phi = torch.eye(num_classes, device=device, dtype=torch.float32)\n\n        # Stable per-sample pseudo-label memory. −1 = \"not accepted\".\n        # 13,872 × int64 = 111 KB. (int8 would do; int64 keeps indexing simple.)\n        self.prev_pl = torch.full((n_unlabeled,), -1, dtype=torch.long, device=device)\n        self.cur_pl  = torch.full((n_unlabeled,), -1, dtype=torch.long, device=device)\n\n        self.trans_counts  = torch.zeros(num_classes, num_classes, device=device)\n        self.neighbor_mask = torch.zeros(num_classes, num_classes,\n                                         dtype=torch.bool, device=device)\n        self.theta = 0.0\n\n        # Diagnostics (Figure 1)\n        self.seen_counts   = torch.zeros(num_classes, device=device)  # argmax seen\n        self.accept_counts = torch.zeros(num_classes, device=device)  # accepted\n        self.pure_counts   = torch.zeros(num_classes, device=device)  # correct | accepted\n\n    # ── per-epoch reset ─────────────────────────────────────────────────────\n    def start_epoch(self):\n        self.cur_pl.fill_(-1)\n        self.trans_counts.zero_()\n        self.seen_counts.zero_()\n        self.accept_counts.zero_()\n        self.pure_counts.zero_()\n\n    # ── called once per μ-chunk — FULLY VECTORIZED (BUG FIX #2) ─────────────\n    @torch.no_grad()\n    def record_chunk(self, idx, pseudo_labels, accept_mask, true_labels=None):\n        \"\"\"\n        idx           : (b,) stable dataset indices — arrives from the DataLoader on CPU\n        pseudo_labels : (b,) argmax of the (debiased) teacher distribution\n        accept_mask   : (b,) bool\n        true_labels   : (b,) optional — DIAGNOSTIC ONLY, never touches training.\n\n        No Python-level loop over the batch anywhere in here. This runs\n        μ=4 × 76 steps × 80 epochs; a per-sample loop is not survivable.\n        \"\"\"\n        # ── BUG FIX #3 — DEVICE CONSISTENCY. ────────────────────────────────\n        # `idx` comes off the DataLoader as a CPU LongTensor. `prev_pl`/`cur_pl`\n        # live on CUDA. Indexing a CUDA tensor with a CPU index tensor is the\n        # classic silent CPU/CUDA mismatch. Move it explicitly, then assert.\n        idx           = idx.to(self.device, non_blocking=True).long()\n        pseudo_labels = pseudo_labels.to(self.device).long()\n        accept_mask   = accept_mask.to(self.device).bool()\n        assert idx.device == self.prev_pl.device, \\\n            f'device mismatch: idx={idx.device} prev_pl={self.prev_pl.device}'\n\n        # per-class argmax count, pre-acceptance (denominator of the accept rate)\n        self.seen_counts += torch.bincount(pseudo_labels, minlength=self.K).float()\n\n        if not bool(accept_mask.any()):\n            return\n\n        idx_a = idx[accept_mask]\n        pl_a  = pseudo_labels[accept_mask]\n        self.accept_counts += torch.bincount(pl_a, minlength=self.K).float()\n\n        # ── BUG FIX #2a — VECTORIZED pseudo-label memory write ──────────────\n        self.cur_pl.index_put_((idx_a,), pl_a, accumulate=False)\n\n        # ── BUG FIX #2b — VECTORIZED transition counting ────────────────────\n        # bincount over the flattened (i·K + j) index. No `for` over the batch.\n        prev_a = self.prev_pl[idx_a]                       # (n_acc,)\n        both   = prev_a >= 0                               # accepted last epoch too\n        if bool(both.any()):\n            flat = prev_a[both] * self.K + pl_a[both]      # (n,)  i*K + j\n            self.trans_counts += torch.bincount(\n                flat, minlength=self.K * self.K\n            ).reshape(self.K, self.K).float()\n\n        # ── DIAGNOSTIC ONLY — held-out unlabeled labels. Never used for\n        #    training, acceptance, Φ, the checkpoint criterion, or selection.\n        if true_labels is not None:\n            tl = true_labels.to(self.device).long()[accept_mask]\n            hit = pl_a == tl\n            if bool(hit.any()):\n                self.pure_counts += torch.bincount(pl_a[hit], minlength=self.K).float()\n\n    # ── supervised soft confusion C, on the LABELED set ─────────────────────\n    @torch.no_grad()\n    def estimate_C(self, teacher, labeled_eval_loader, device,\n                   temp=PASS_TEACHER_TEMP, amp=USE_AMP):\n        \"\"\"\n        C[i][j] = (1/N_i) · Σ_{x : y(x)=i} q_j(x),  teacher in EVAL mode.\n        Row-stochastic by construction. Soft (mean prob), not hard argmax —\n        lower variance, and it captures the near-misses hard confusion discards.\n        ~2.4k images ⇒ ≈10 s/epoch.\n        \"\"\"\n        was_training = teacher.training\n        teacher.eval()\n\n        Csum = torch.zeros(self.K, self.K, device=device)\n        Ccnt = torch.zeros(self.K, device=device)\n\n        for xb, yb in labeled_eval_loader:\n            xb = xb.to(device, non_blocking=True)\n            yb = yb.to(device, non_blocking=True).long()\n            with autocast(device_type=DEVICE_TYPE, enabled=amp):\n                zt = teacher(xb, return_tokens=False)\n            q = F.softmax(zt.float() / temp, dim=-1)       # fp32 — fp16 softmax saturates\n            Csum.index_add_(0, yb, q)                      # vectorized row accumulate\n            Ccnt += torch.bincount(yb, minlength=self.K).float()\n            del xb, yb, zt, q\n\n        if was_training:\n            teacher.train()\n\n        C = Csum / Ccnt.clamp_min(1.0).unsqueeze(1)\n        empty = Ccnt == 0\n        if bool(empty.any()):                              # unreachable with a stratified split\n            C[empty] = torch.eye(self.K, device=device)[empty]\n        return C\n\n    # ── T + fuse + EMA + re-derive N(j) ─────────────────────────────────────\n    @torch.no_grad()\n    def _normalize_transitions(self):\n        row = self.trans_counts.sum(dim=1, keepdim=True)   # (K,1)\n        T = self.trans_counts / row.clamp_min(1.0)\n        # ASSUMPTION (unspecified in the plan): a class with zero observed accepted\n        # transitions this epoch gets the IDENTITY row. \"No observed drift ⇒ no\n        # flow.\" Conservative — it pulls Φ toward I and never invents structure.\n        empty = row.squeeze(1) == 0\n        if bool(empty.any()):\n            T[empty] = torch.eye(self.K, device=self.device)[empty]\n        return T\n\n    @torch.no_grad()\n    def update_phi(self, C):\n        \"\"\"Φ̃ = α·C + (1−α)·T ;  Φ ← m·Φ + (1−m)·Φ̃ ;  roll prev_pl ;  re-derive N(j).\"\"\"\n        T = self._normalize_transitions()\n        Phi_tilde = self.alpha * C + (1.0 - self.alpha) * T\n        self.Phi  = self.momentum * self.Phi + (1.0 - self.momentum) * Phi_tilde\n        self.prev_pl.copy_(self.cur_pl)          # this epoch's PLs become last epoch's\n        self._derive_neighbourhoods()\n        return self.Phi\n\n    @torch.no_grad()\n    def _derive_neighbourhoods(self):\n        \"\"\"\n        N(j) is derived FROM Φ ITSELF — never hand-coded from AREDS.\n\n            Ψ = (Φ + Φᵀ)/2,   diag(Ψ) = 0\n            θ = mean off-diagonal(Ψ)\n            N(j) = top-`topk` entries of row j of Ψ that STRICTLY exceed θ\n\n        Classes with no learned confusion get an EMPTY N(j) and fall back to\n        FixMatch-like behaviour. At Φ = I: Ψ is all-zero off-diagonal, θ = 0,\n        `> θ` is strict ⇒ every N(j) is empty. Exactly right for epoch 0.\n        \"\"\"\n        Psi = 0.5 * (self.Phi + self.Phi.t())\n        Psi = Psi - torch.diag(torch.diag(Psi))            # zero the diagonal\n        off = ~torch.eye(self.K, dtype=torch.bool, device=self.device)\n        self.theta = Psi[off].mean().item()\n\n        vals, cols = Psi.topk(self.topk, dim=1)            # (K, topk)\n        keep = vals > self.theta                           # strict\n        nb = torch.zeros(self.K, self.K, dtype=torch.bool, device=self.device)\n        nb.scatter_(1, cols, keep)                         # vectorized\n        nb.fill_diagonal_(False)\n        self.neighbor_mask = nb\n\n    # ── diagnostics ─────────────────────────────────────────────────────────\n    @torch.no_grad()\n    def epoch_diagnostics(self):\n        acc_rate = (self.accept_counts / self.seen_counts.clamp_min(1.0)).cpu().numpy()\n        purity   = (self.pure_counts   / self.accept_counts.clamp_min(1.0)).cpu().numpy()\n        return {\n            'accept_rate':   acc_rate,                     # (K,)\n            'pl_purity':     purity,                       # (K,)  DIAGNOSTIC ONLY\n            'accept_counts': self.accept_counts.cpu().numpy(),\n            'theta':         self.theta,\n            'neighbours': {\n                CLASSES[j]: [CLASSES[c] for c in range(self.K)\n                             if bool(self.neighbor_mask[j, c])]\n                for j in range(self.K)\n            },\n        }\n\n    def state_dict(self):\n        return {'Phi': self.Phi.cpu(), 'prev_pl': self.prev_pl.cpu(),\n                'neighbor_mask': self.neighbor_mask.cpu(), 'theta': self.theta}\n\n    def load_state_dict(self, sd):\n        self.Phi = sd['Phi'].to(self.device)\n        self.prev_pl = sd['prev_pl'].to(self.device)\n        self.neighbor_mask = sd['neighbor_mask'].to(self.device)\n        self.theta = sd['theta']\n\n\n# ═════════════════════════════════════════════════════════════════════════════\n@torch.no_grad()\ndef directional_debias(z, Phi, lam_d, eps=PASS_EPS, one_sided=PASS_ONE_SIDED):\n    \"\"\"\n    Directional debiasing — the matrix-valued generalisation of DebiasPL.\n\n        inflow_j(q) = Σ_{i≠j} Φ[i][j] · q_i\n        u_j         = (inflow_j + ε) / Σ_k (inflow_k + ε)\n        z̃_j         = z_j − λ_d · ReLU( log(K · u_j) )     ← ONE-SIDED. MANDATORY.\n\n    z   : (B,K) TEACHER logits.  Phi : (K,K).  Returns (B,K) fp32.\n\n    ── WHY THE ReLU IS NON-NEGOTIABLE ──────────────────────────────────────\n    Without it, classes with BELOW-average inflow get *boosted*. The off-spectrum\n    classes (AMD/CSR/MH) have almost no inflow — so they are precisely the ones\n    boosted, and probability mass drains OUT of the spectrum. On a torn\n    NORMAL/DRUSEN sample this inflates distal mass ~2.8×, which pushes the\n    acceptance gate below toward rejecting the exact sample this method exists to\n    rescue. The two mechanisms would fight each other. With the ReLU we only\n    *discount absorbers* and never *inflate non-absorbers*. Cell 17 proves it\n    numerically at runtime. DO NOT REMOVE.\n\n    ── SELF-WARM-UP ────────────────────────────────────────────────────────\n    At Φ = I every inflow is exactly 0 ⇒ u is uniform ⇒ log(K·(1/K)) = 0 ⇒ the\n    correction is EXACTLY zero. No log(0), no special-casing, no warmup hack.\n    \"\"\"\n    # Preserve dtype instead of forcing fp32: production always passes fp32\n    # teacher logits, so this is a no-op there — but VERIFY 2 needs float64\n    # end-to-end to check the algebra to machine precision, not to fp32 noise.\n    if z.dtype != torch.float64:\n        z = z.float()\n    K = z.size(1)\n    q = F.softmax(z, dim=-1)                               # (B,K)\n\n    # Zeroing the diagonal is what enforces i ≠ j in the inflow sum.\n    Phi_off = Phi - torch.diag(torch.diag(Phi)).to(Phi.dtype)   # (K,K)\n    Phi_off = Phi_off.to(z.dtype)\n    inflow  = q @ Phi_off                                  # (B,K) — vectorized\n\n    u = inflow + eps\n    u = u / u.sum(dim=1, keepdim=True)\n    corr = torch.log(K * u)                                # (B,K)\n    if one_sided:\n        corr = F.relu(corr)                                # ← THE ReLU\n    return z - lam_d * corr\n\n\n@torch.no_grad()\ndef ordinal_entropy_gate(q_tilde, neighbor_mask,\n                         tau_lo=PASS_TAU_LO, beta=PASS_BETA):\n    \"\"\"\n    Accept iff   q̃_ĵ ≥ τ_lo   AND   distal_mass ≤ β.\n\n        local  = Σ_{c ∈ {ĵ} ∪ N(ĵ)}  q̃_c      honest ordinal indecision — TOLERATED\n        distal = 1 − local                     the model is genuinely lost — NOT tolerated\n\n    τ_lo = 0.45 is deliberate. A genuine boundary sample has confidence ≈ 0.55\n    *by definition of being a boundary case* — that IS the sample we are rescuing.\n    Confidence is not the discriminating signal here; DISTAL MASS is. τ_lo is only\n    a sanity floor against near-uniform garbage. Low confidence is safe because\n    accepted samples train on a SOFT target, not a hard label.\n\n    Accepted samples train on q̃ restricted to {ĵ} ∪ N(ĵ) and RENORMALISED —\n    distal mass is stripped, not merely down-weighted.\n\n    Degenerate case, and it is the intended one: if N(ĵ) = ∅ (no learned confusion,\n    e.g. at Φ = I), local = {ĵ}, distal = 1 − q̃_ĵ, and the two conditions collapse\n    to a hard threshold at max(τ_lo, 1−β) = 0.90 with a one-hot target — i.e.\n    FixMatch. Clean fallback, no special-casing.\n\n    ── BUG FIX #2c: fully vectorized. No Python loop over the batch dimension. ──\n    \"\"\"\n    B, K = q_tilde.shape\n    conf, jhat = q_tilde.max(dim=1)                        # (B,), (B,)\n\n    local_mask = neighbor_mask[jhat].clone()               # (B,K) — row gather\n    local_mask.scatter_(1, jhat.unsqueeze(1), True)        # ∪ {ĵ}\n\n    local  = (q_tilde * local_mask).sum(dim=1)             # (B,) masked sum\n    distal = (1.0 - local).clamp_min(0.0)                  # (B,)\n\n    accept = (conf >= tau_lo) & (distal <= beta)           # (B,)\n\n    soft = q_tilde * local_mask                            # strip distal mass\n    soft = soft / soft.sum(dim=1, keepdim=True).clamp_min(1e-8)   # renormalise\n    return accept, jhat, conf, distal, soft\n\n\n@torch.no_grad()\ndef asym_sample_weight(y, student_probs, W=W_ASYM, mode=PASS_ASYM_MODE):\n    \"\"\"\n    Per-sample multiplier from the asymmetric under-grading cost.\n\n    ASSUMPTION: the plan defines w(y, c) but calls it a \"per-sample multiplier\",\n    leaving `c` unbound. We bind c to the model's CURRENT DECISION:\n        mode='argmax'   (default)  w_i = W[y_i, argmax_c p_{i,c}]      hard, detached\n        mode='expected'            w_i = Σ_c p_{i,c} · W[y_i, c]       smooth\n    Both give exactly 1.0 for off-spectrum pairs, and 'argmax' gives exactly 1.0\n    when the model is already correct — so the cost only bites on live errors.\n\n    y : (B,) true label (L_sup) or accepted pseudo-label (L_u).\n    \"\"\"\n    Wy = W[y]                                              # (B,K)\n    if mode == 'expected':\n        return (student_probs.float() * Wy).sum(dim=1)     # (B,)\n    chat = student_probs.argmax(dim=1)                     # (B,)\n    return Wy.gather(1, chat.unsqueeze(1)).squeeze(1)      # (B,)\n\n\nprint('PASS core defined:')\nprint(f'  spectrum ranks     : ' +\n      '  '.join(f'{CLASSES[i]}={RANK[i].item()}' for i in range(NUM_CLASSES)))\nprint(f'  W_ASYM             : {tuple(W_ASYM.shape)}   '\n      f'w(DRUSEN→NORMAL)={W_ASYM[CLASS2IDX[\"DRUSEN\"], CLASS2IDX[\"NORMAL\"]]:.2f}  '\n      f'w(NORMAL→DRUSEN)={W_ASYM[CLASS2IDX[\"NORMAL\"], CLASS2IDX[\"DRUSEN\"]]:.2f}  '\n      f'(under-grading costs more)')\nprint(f'  ConfusionFlowTracker / directional_debias / ordinal_entropy_gate / asym_sample_weight')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:15.751621Z","iopub.execute_input":"2026-07-18T16:42:15.752218Z","iopub.status.idle":"2026-07-18T16:42:16.030166Z","shell.execute_reply.started":"2026-07-18T16:42:15.752166Z","shell.execute_reply":"2026-07-18T16:42:16.029554Z"}},"outputs":[{"name":"stdout","text":"PASS core defined:\n  spectrum ranks     : AMD=-1  CNV=2  CSR=-1  DME=-1  DR=-1  DRUSEN=1  MH=-1  NORMAL=0\n  W_ASYM             : (8, 8)   w(DRUSEN→NORMAL)=3.00  w(NORMAL→DRUSEN)=2.00  (under-grading costs more)\n  ConfusionFlowTracker / directional_debias / ordinal_entropy_gate / asym_sample_weight\n","output_type":"stream"}],"execution_count":13},{"id":"2a11eb7b-9342-4da1-bc8b-d6602b493cc4","cell_type":"markdown","source":"## Verification cells — run these before launching R0\n\nFour checks. They are `assert`s, not decoration. If any of them fails, there is a bug and\nthe training run is worthless.\n\n1. **`Φ⁽⁰⁾ = I` and the correction is exactly zero at epoch 0.** Not \"approximately zero\" —\n   `max|z̃ − z|` must print `0.000000e+00`.\n2. **Proposition 1** — rank-one Φ ⇒ *exact* reduction to marginal DebiasPL plus a `log(1−q)`\n   confidence modulation, both inside a ReLU. Must hold to ~1e-15. **Note: this is exact only\n   in the `ε → 0` limit** — `ε = 1e-3` is a numerical floor that sits outside the algebra, so\n   the cell sets `ε = 0`. If you quote \"verified to machine precision\" in the paper, that is\n   the claim you can defend.\n3. **The ReLU is mandatory** — a torn NORMAL/DRUSEN sample, with and without it.\n4. **The four-case gate test** — and specifically case (a) vs case (d): near-identical\n   confidence, wildly different distal mass, opposite decisions. That pair is the proof that\n   the gate is a *mechanism*, not a lowered threshold. It is Figure 3.","metadata":{}},{"id":"b2c726cc-b95b-4ec9-80fc-c25cd97cf881","cell_type":"code","source":"# ═════════════════════════════════════════════════════════════════════════════\n#  VERIFY 1 — Φ⁽⁰⁾ is the LITERAL identity, and at Φ = I the debias correction\n#             is EXACTLY zero (not approximately). This is what licenses the\n#             \"the AREDS chain was discovered, not encoded\" claim.\n# ═════════════════════════════════════════════════════════════════════════════\n_v1_tracker = ConfusionFlowTracker(NUM_CLASSES, n_unlabeled=N_UNLABELED, device=DEVICE)\n_I = torch.eye(NUM_CLASSES, device=DEVICE)\n\n# (1) Φ⁽⁰⁾ is bit-for-bit the identity.\nassert torch.equal(_v1_tracker.Phi, _I), 'Φ⁽⁰⁾ is NOT the identity matrix'\nprint(f'Φ⁽⁰⁾ == I exactly (bitwise)        : True')\nprint(f'Φ⁽⁰⁾ off-diagonal max |·|          : '\n      f'{(_v1_tracker.Phi - _I).abs().max().item():.3e}')\n\n# (2) inflow is identically zero at Φ = I  ⇒  u is uniform  ⇒  log(K·1/K) = 0.\ntorch.manual_seed(0)\n_z = torch.randn(256, NUM_CLASSES, device=DEVICE) * 3.0\n_q = F.softmax(_z, dim=-1)\n_Phi_off = _v1_tracker.Phi - torch.diag(torch.diag(_v1_tracker.Phi))\n_inflow = _q @ _Phi_off\nprint(f'max |inflow| at Φ = I              : {_inflow.abs().max().item():.3e}')\n\n# (3) the correction is EXACTLY zero, at full λ_d, over 256 random logit vectors.\n_zt = directional_debias(_z, _v1_tracker.Phi, lam_d=PASS_LAMBDA_D_MAX,\n                         eps=PASS_EPS, one_sided=True)\n_err = (_zt - _z).abs().max().item()\nprint(f'max |z̃ − z| at Φ = I, λ_d = {PASS_LAMBDA_D_MAX}    : {_err:.6e}')\nassert _err == 0.0, f'correction at Φ=I is not exactly zero (got {_err:.3e})'\n\n# (4) at Φ = I every neighbourhood is EMPTY ⇒ the gate degrades cleanly to FixMatch.\n_v1_tracker._derive_neighbourhoods()\n_n_nb = int(_v1_tracker.neighbor_mask.sum().item())\nprint(f'θ = mean off-diag(Ψ) at Φ = I      : {_v1_tracker.theta:.6f}')\nprint(f'total neighbours at Φ = I          : {_n_nb}   (must be 0 → empty N(j) ∀j)')\nassert _n_nb == 0, 'Φ=I must yield empty neighbourhoods'\n\nprint()\nprint('✅ VERIFY 1 PASSED — Φ⁽⁰⁾ = I, correction is exactly 0, N(j) = ∅ ∀j.')\nprint('   The mechanism self-warms-up. The 10-epoch λ_d ramp is belt-and-braces.')\ndel _v1_tracker, _z, _q, _Phi_off, _inflow, _zt","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:16.03098Z","iopub.execute_input":"2026-07-18T16:42:16.031275Z","iopub.status.idle":"2026-07-18T16:42:16.671304Z","shell.execute_reply.started":"2026-07-18T16:42:16.031254Z","shell.execute_reply":"2026-07-18T16:42:16.67014Z"}},"outputs":[{"name":"stdout","text":"Φ⁽⁰⁾ == I exactly (bitwise)        : True\nΦ⁽⁰⁾ off-diagonal max |·|          : 0.000e+00\nmax |inflow| at Φ = I              : 0.000e+00\nmax |z̃ − z| at Φ = I, λ_d = 1.0    : 0.000000e+00\nθ = mean off-diag(Ψ) at Φ = I      : 0.000000\ntotal neighbours at Φ = I          : 0   (must be 0 → empty N(j) ∀j)\n\n✅ VERIFY 1 PASSED — Φ⁽⁰⁾ = I, correction is exactly 0, N(j) = ∅ ∀j.\n   The mechanism self-warms-up. The 10-epoch λ_d ramp is belt-and-braces.\n","output_type":"stream"}],"execution_count":14},{"id":"0b10faea-732d-48b2-bf5b-780145a51475","cell_type":"code","source":"# ═════════════════════════════════════════════════════════════════════════════\n#  VERIFY 2 — PROPOSITION 1.\n#\n#  If confusion carries NO directional structure, i.e. Φ[i][j] = π_j ∀ i ≠ j, then\n#\n#      inflow_j(q) = Σ_{i≠j} π_j·q_i = π_j·(1 − q_j)\n#      z̃ = z − λ_d · ReLU[ log π_j + log(1 − q_j) + c ]      c = log K − log S\n#                                                             S = Σ_k π_k(1 − q_k)\n#\n#  The log π term is EXACTLY DebiasPL's marginal correction. The log(1−q) term is a\n#  sample-wise confidence modulation. Hence directional debiasing STRICTLY generalises\n#  marginal debiasing, and reduces to it precisely when confusion is assumed to carry\n#  no directional structure.  ⇒ \"that's just DebiasPL\" becomes impossible to say.\n#\n#  ⚠️  THE REDUCTION IS EXACT ONLY AS ε → 0. The production ε=1e-3 is a numerical\n#      FLOOR that sits OUTSIDE the algebra: log(π_j(1−q_j) + ε) ≠ log π_j + log(1−q_j).\n#      So this cell sets ε = 0 and computes in float64. The ε=1e-3 discrepancy is\n#      printed too, honestly, so you know exactly what you can claim in the paper.\n# ═════════════════════════════════════════════════════════════════════════════\ntorch.manual_seed(0)\n_K = NUM_CLASSES\n\n# a marginal class prior π, and the rank-one Φ it induces\n_pi = torch.distributions.Dirichlet(torch.full((_K,), 2.0)).sample().double().to(DEVICE)\n_Phi_r1 = _pi.unsqueeze(0).repeat(_K, 1)                  # Φ[i][j] = π_j  ∀ i,j\n_z = (torch.randn(512, _K, device=DEVICE) * 2.5).double()\n_lam = 0.7\n\n# ── LHS: the general directional-debiasing implementation, with ε = 0 ────────\n# NOTE: fed float64 end-to-end (not cast to fp32) so this checks the ALGEBRA\n# to machine precision, uncontaminated by fp32 rounding. directional_debias()\n# now preserves dtype instead of forcing float() — production callers still\n# get fp32 as before since teacher logits are always fp32 there.\n_lhs = directional_debias(_z, _Phi_r1, lam_d=_lam,\n                          eps=0.0, one_sided=True)\n\n# ── RHS: the closed form the proposition claims it must equal ────────────────\n_q = F.softmax(_z, dim=-1)                                # (B,K) float64\n_S = (_pi.unsqueeze(0) * (1.0 - _q)).sum(dim=1, keepdim=True)      # (