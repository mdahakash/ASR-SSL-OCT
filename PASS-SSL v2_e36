 selection. State this in the figure caption and\n#  in the text. Reviewers watch for it.\n# ═════════════════════════════════════════════════════════════════════════════\n_H   = np.load(f'pass_{RUN_NAME}_phi_history.npz', allow_pickle=True)\n_phi = _H['phi']            # (E, K, K)\n_acc = _H['accept']         # (E, K)\n_pur = _H['purity']         # (E, K)   DIAGNOSTIC ONLY\n_E   = _phi.shape[0]\n_eps_x = np.arange(1, _E + 1)\n\n_SPEC = ['NORMAL', 'DRUSEN', 'CNV']\n_OFF  = ['AMD', 'CSR', 'MH', 'DR', 'DME']\n\n# ── FIGURE 1 ────────────────────────────────────────────────────────────────\nfig, axes = plt.subplots(2, 1, figsize=(13, 9), sharex=True)\n\nfor c in _SPEC:\n    axes[0].plot(_eps_x, _acc[:, CLASS2IDX[c]], lw=2.4, label=f'{c}  (spectrum)')\nfor c in _OFF:\n    axes[0].plot(_eps_x, _acc[:, CLASS2IDX[c]], lw=1.0, ls='--', alpha=0.55, label=c)\naxes[0].set_ylabel('pseudo-label acceptance rate')\naxes[0].set_title(f'Figure 1 — {RUN_NAME}: ordinal collapse in the pseudo-label stream',\n                  fontsize=13, fontweight='bold')\naxes[0].legend(ncol=4, fontsize=9)\naxes[0].grid(alpha=0.3)\n\nfor c in _SPEC:\n    axes[1].plot(_eps_x, _pur[:, CLASS2IDX[c]], lw=2.4, label=f'{c}  (spectrum)')\nfor c in _OFF:\n    axes[1].plot(_eps_x, _pur[:, CLASS2IDX[c]], lw=1.0, ls='--', alpha=0.55, label=c)\naxes[1].set_ylabel('pseudo-label purity')\naxes[1].set_xlabel('epoch')\naxes[1].set_title('per-class pseudo-label purity   '\n                  '[held-out unlabeled labels - DIAGNOSTIC ONLY, never used for '\n                  'training or model selection]', fontsize=10)\naxes[1].legend(ncol=4, fontsize=9)\naxes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.savefig(f'pass_{RUN_NAME}_fig1_acceptance_purity.png', dpi=200, bbox_inches='tight')\nplt.show()\n\n# ── FIGURE 2 — the money figure ─────────────────────────────────────────────\n_P = _phi[-1].copy()\nnp.fill_diagonal(_P, 0.0)\n\nfig, ax = plt.subplots(figsize=(9.5, 8))\nsns.heatmap(_P, annot=True, fmt='.3f', cmap='rocket_r',\n            xticklabels=CLASSES, yticklabels=CLASSES, ax=ax,\n            cbar_kws={'label': 'Phi[i][j]  -  probability flow  i -> j'},\n            linewidths=0.5, linecolor='white')\nax.set_xlabel('to class  j')\nax.set_ylabel('from class  i')\nax.set_title(f'Figure 2 — {RUN_NAME}: confusion-flow matrix Phi at epoch {_E} '\n             f'(diagonal zeroed)\\nPhi(0) = I — no clinical prior was ever supplied',\n             fontsize=12, fontweight='bold')\n\n# overlay the AREDS adjacency and let the figure do the arguing\nimport matplotlib.patches as mpatches\nfor _i, _j in [(_iN, _iD), (_iD, _iN), (_iD, _iC), (_iC, _iD)]:\n    ax.add_patch(mpatches.Rectangle((_j, _i), 1, 1, fill=False,\n                                    edgecolor='#00b894', lw=3, ls='--'))\nfor _i, _j in [(_iN, _iC), (_iC, _iN)]:\n    ax.add_patch(mpatches.Rectangle((_j, _i), 1, 1, fill=False,\n                                    edgecolor='#0984e3', lw=3, ls=':'))\nax.legend(handles=[\n    mpatches.Patch(fc='none', ec='#00b894', ls='--', lw=3,\n                   label='AREDS adjacency  (N-D, D-C)   should be HOT'),\n    mpatches.Patch(fc='none', ec='#0984e3', ls=':', lw=3,\n                   label='AREDS NON-adjacency  (N-C)    should be COLD'),\n], loc='upper left', bbox_to_anchor=(1.28, 1.0), fontsize=9)\n\nplt.tight_layout()\nplt.savefig(f'pass_{RUN_NAME}_fig2_phi_heatmap.png', dpi=200, bbox_inches='tight')\nplt.show()\n\n# ── the decision gate, in numbers ───────────────────────────────────────────\n_dn, _nd = _P[_iD, _iN], _P[_iN, _iD]\n_dc, _cd = _P[_iD, _iC], _P[_iC, _iD]\n_nc, _cn = _P[_iN, _iC], _P[_iC, _iN]\n_offdiag = _P[~np.eye(NUM_CLASSES, dtype=bool)]\n\nprint('=' * 78)\nprint(f'  WEEK-1 DECISION GATE  ({RUN_NAME}, epoch {_E})')\nprint('=' * 78)\nprint(f'  Phi[DRUSEN->NORMAL] = {_dn:.4f}      Phi[NORMAL->DRUSEN] = {_nd:.4f}')\nprint(f'  Phi[DRUSEN->CNV]    = {_dc:.4f}      Phi[CNV->DRUSEN]    = {_cd:.4f}')\nprint(f'  Phi[NORMAL->CNV]    = {_nc:.4f}      Phi[CNV->NORMAL]    = {_cn:.4f}   <- want ~0')\nprint(f'  mean off-diagonal   = {_offdiag.mean():.4f}')\nprint()\n_chain    = (_nd + _dn + _dc + _cd) / 4.0\n_nonchain = (_nc + _cn) / 2.0\nprint(f'  chain strength  (N-D, D-C)  = {_chain:.4f}')\nprint(f'  non-chain       (N-C)       = {_nonchain:.4f}')\nprint(f'  chain / non-chain ratio     = {_chain/max(_nonchain,1e-8):.2f}x   '\n      f'(want >> 1  -> AREDS chain recovered)')\nprint(f'  asymmetry  Phi[D->N]/Phi[N->D] = {_dn/max(_nd,1e-8):.2f}x   '\n      f'(want > ~1.3 -> debiasing has something to bite on)')\nprint()\nif _chain / max(_nonchain, 1e-8) > 2.0 and _dn / max(_nd, 1e-8) > 1.3:\n    print('  GO. Clean N-D-C chain with near-zero (N,C), and NORMAL absorbs.')\n    print('  You have the discovery claim AND the mechanism has something to correct.')\n    print('  Proceed to R1-R4.')\nelse:\n    print('  MARGINAL. Before re-training, try the plan\\'s week-1 escape hatch:')\n    print('  raise PASS_PHI_ALPHA toward 1.0 (lean on the lower-variance supervised')\n    print('  confusion C), lengthen PASS_PHI_MOMENTUM to 0.95, and RE-PLOT FROM')\n    print(f'  pass_{RUN_NAME}_phi_history.npz — no re-training needed.')\n    print('  If it is still flat, fall back to a soft AREDS prior on Phi(0). You lose')\n    print('  the discovery claim; you keep the method.')\nprint('=' * 78)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"72659929-e35f-4839-adba-22202e10a51d","cell_type":"code","source":"class TemperatureScaler(nn.Module):\n    \"\"\"Fits a single scalar T on the validation set.\"\"\"\n    def __init__(self):\n        super().__init__()\n        self.temperature = nn.Parameter(torch.ones(1, device=DEVICE))\n    def forward(self, logits):\n        return logits / self.temperature.clamp(min=0.5, max=5.0)\n\n\ntemp_scaler = TemperatureScaler()\n\nprint('Collecting val logits for temperature calibration ...')\nckpt_cal = torch.load(CKPT_BEST, map_location=DEVICE, weights_only=False)\nraw_s_cal = student.module if hasattr(student, 'module') else student\nraw_s_cal.load_state_dict(ckpt_cal['student_state_dict'])\nprint(f\"Loaded ep {ckpt_cal['epoch']}, val AUC={ckpt_cal['val_auc']:.4f}\")\ndel ckpt_cal\n\nstudent.eval()\nval_logits_list, val_labels_list = [], []\nwith torch.no_grad():\n    for xb, yb in tqdm(val_loader, desc='Val logits', leave=False):\n        xb = xb.to(DEVICE, non_blocking=True)\n        with autocast(device_type=DEVICE_TYPE, enabled=USE_AMP):\n            logits = student(xb, return_tokens=False)\n        val_logits_list.append(logits.float().cpu())\n        val_labels_list.append(yb)\n        del xb, logits\n\nval_logits_all = torch.cat(val_logits_list).to(DEVICE)\nval_labels_all = torch.cat(val_labels_list).to(DEVICE)\ndel val_logits_list, val_labels_list\ntorch.cuda.empty_cache()\n\nnll_crit    = nn.CrossEntropyLoss()\noptimizer_T = torch.optim.LBFGS([temp_scaler.temperature], lr=0.01, max_iter=50)\n\ndef _ts_closure():\n    optimizer_T.zero_grad()\n    loss_ts = nll_crit(temp_scaler(val_logits_all), val_labels_all)\n    loss_ts.backward()\n    return loss_ts\n\nfor _ts_step in range(5):\n    optimizer_T.step(_ts_closure)\n\nT_opt = temp_scaler.temperature.item()\nprint(f'\\nCalibrated temperature T = {T_opt:.4f}')\nwith open(f'pass_{RUN_NAME}_temperature.json', 'w') as f:\n    json.dump({'temperature': T_opt}, f)\n\ndel val_logits_all, val_labels_all\ntorch.cuda.empty_cache()\ngc.collect()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"198f860f-da80-4a6f-a6c6-546b2885336c","cell_type":"code","source":"ckpt = torch.load(CKPT_BEST, map_location=DEVICE, weights_only=False)\nraw_student = student.module if hasattr(student, 'module') else student\nraw_student.load_state_dict(ckpt['student_state_dict'])\nprint(f\"Loaded best checkpoint (ep {ckpt['epoch']}, val AUC={ckpt['val_auc']:.4f})\")\nprint(f\"  run={ckpt.get('run')}  flags={ckpt.get('flags')}\")\ndel ckpt\n\n\nclass TempScaledModel(nn.Module):\n    def __init__(self, model, scaler):\n        super().__init__()\n        self.model  = model\n        self.scaler = scaler\n    def forward(self, x, **kwargs):\n        return self.scaler(self.model(x, **kwargs))\n\n\nstudent_ts = TempScaledModel(student, temp_scaler)\n\n_, _, test_probs, test_targets = evaluate(\n    student_ts, test_loader, focal_loss, DEVICE, split='Test', tta=True)\n\ntest_metrics, test_preds_idx, test_pred_names, test_true_names = compute_metrics(\n    test_probs, test_targets, split_name=f'PASS {RUN_NAME} — 15% labeled')\n\nwith open(f'pass_{RUN_NAME}_test_metrics.json', 'w') as f:\n    json.dump(test_metrics, f, indent=2)\n\n# ── Confusion matrix ────────────────────────────────────────────────────────\ncm = confusion_matrix(test_true_names, test_pred_names, labels=CLASSES)\nfig, ax = plt.subplots(figsize=(10, 8))\nConfusionMatrixDisplay(confusion_matrix=cm, display_labels=CLASSES).plot(\n    cmap='Blues', ax=ax, values_format='d')\nax.set_title(f'PASS {RUN_NAME} — confusion matrix (15% labeled)',\n             fontsize=14, fontweight='bold')\nplt.xticks(rotation=45, ha='right')\nplt.tight_layout()\nplt.savefig(f'pass_{RUN_NAME}_confusion_matrix.png', dpi=200, bbox_inches='tight')\nplt.show()\n\n# ── Per-class ROC ───────────────────────────────────────────────────────────\nfig, axes = plt.subplots(2, 4, figsize=(20, 10))\ntest_ohe = np.zeros((len(test_targets), NUM_CLASSES))\ntest_ohe[np.arange(len(test_targets)), test_targets] = 1\nfor idx_, (cls_name, ax) in enumerate(zip(CLASSES, axes.flat)):\n    fpr, tpr, _ = roc_curve(test_ohe[:, idx_], test_probs[:, idx_])\n    ax.plot(fpr, tpr, lw=2, label=f'AUC={auc(fpr, tpr):.3f}')\n    ax.plot([0, 1], [0, 1], 'k--', lw=0.5)\n    ax.set_title(cls_name)\n    ax.legend(loc='lower right')\n    ax.set_xlabel('FPR'); ax.set_ylabel('TPR')\nplt.suptitle(f'PASS {RUN_NAME} — per-class ROC', fontsize=14, fontweight='bold')\nplt.tight_layout()\nplt.savefig(f'pass_{RUN_NAME}_roc_curves.png', dpi=200, bbox_inches='tight')\nplt.show()\n\n# ── The table that matters: the ordinal-collapse signature ──────────────────\nprint('\\n' + '=' * 74)\nprint(f'  ORDINAL-COLLAPSE SIGNATURE — {RUN_NAME}')\nprint('  (an ABSORBING class has the HIGHEST recall and the LOWEST precision)')\nprint('=' * 74)\nprec = precision_score(test_true_names, test_pred_names,\n                       labels=CLASSES, average=None, zero_division=0)\nrec  = recall_score(test_true_names, test_pred_names,\n                    labels=CLASSES, average=None, zero_division=0)\nf1   = f1_score(test_true_names, test_pred_names,\n                labels=CLASSES, average=None, zero_division=0)\nprint(f'  {\"class\":<8s} {\"precision\":>10s} {\"recall\":>8s} {\"F1\":>8s}   {\"P-R\":>7s}  reading')\nprint('  ' + '-' * 70)\nfor i_, c_ in enumerate(CLASSES):\n    gap = prec[i_] - rec[i_]\n    if c_ in ['NORMAL', 'DRUSEN', 'CNV']:\n        tag = 'ABSORBER (sink)' if gap < -0.05 else ('DONOR' if gap > 0.05 else 'balanced')\n        tag += '  <- spectrum'\n    else:\n        tag = 'off-spectrum'\n    print(f'  {c_:<8s} {prec[i_]:10.4f} {rec[i_]:8.4f} {f1[i_]:8.4f}   {gap:+7.4f}  {tag}')\nprint('  ' + '-' * 70)\nprint(f'  GTC-v5 reference : NORMAL P=0.8065 R=0.9033 (absorber), '\n      f'DRUSEN F1=0.8016, overall 0.9156')\nprint(f'  this run         : NORMAL P={prec[_iN]:.4f} R={rec[_iN]:.4f}, '\n      f'DRUSEN F1={f1[_iD]:.4f}, overall {test_metrics[\"accuracy\"]:.4f}')\nprint('=' * 74)\n\nprint('\\n' + classification_report(test_true_names, test_pred_names,\n                                   target_names=CLASSES, digits=4))\nprint(f'\\n{RUN_NAME} evaluation complete.')\nprint('   FRAMING RULE: you are at 15% labels. Fully-supervised OCT-C8 SOTA is ~97-98%.')\nprint('   NEVER print your number next to theirs without the label-efficiency framing.')\nprint('   Your axis is LABELS USED, not accuracy. Plot accuracy-vs-label-fraction.')","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}