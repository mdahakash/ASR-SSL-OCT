st()` — so position i in this frame IS dataset\n# index i. This alignment is what makes prev_pl / cur_pl meaningful.\nunlabeled_df = unlabeled_df.reset_index(drop=True)\nlabeled_df   = labeled_df.reset_index(drop=True)\n\n# ── DIAGNOSTIC ONLY ──────────────────────────────────────────────────────────\n# Held-out ground truth for the unlabeled split, indexed by DATASET INDEX.\n# Used exclusively to compute per-class pseudo-label PURITY for Figure 1.\n# It NEVER enters: the loss, the acceptance decision, Φ, the checkpoint\n# criterion, or model selection. Set PASS_LOG_PURITY=False to drop it entirely.\nN_UNLABELED = len(unlabeled_df)\nunlabeled_true_idx = torch.tensor(\n    [CLASS2IDX[l] for l in unlabeled_df['labels'].tolist()], dtype=torch.long\n)   # CPU (N_UNLABELED,) — moved to device per-chunk inside the tracker\n\nprint(f'\\nTest      : {len(test_df):,}')\nprint(f'Val       : {len(val_df):,}')\nprint(f'Labeled   : {len(labeled_df):,}  ({LABELED_RATIO*100:.0f}% labeled)')\nprint(f'Unlabeled : {N_UNLABELED:,}  (labels hidden from training)')\nprint(f'unlabeled_true_idx: {tuple(unlabeled_true_idx.shape)}  '\n      f'[DIAGNOSTIC ONLY — purity figure; never used for training]')\n\nif CACHE_DATASETS:\n    print('\\nPre-computing enhanced image caches ...')\n    labeled_cache = precompute_enhanced(labeled_df);  gc.collect()\n    val_cache     = precompute_enhanced(val_df);      gc.collect()\n    test_cache    = precompute_enhanced(test_df);     gc.collect()\n    unlabeled_cache = None if UNLABELED_ONDISK else precompute_enhanced(unlabeled_df)\nelse:\n    labeled_cache = unlabeled_cache = val_cache = test_cache = None\n    print('\\nDisk mode: no caches built — images loaded on-the-fly each batch.')\n\ngc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-18T16:42:07.996887Z","iopub.execute_input":"2026-07-18T16:42:07.997601Z","iopub.status.idle":"2026-07-18T16:42:09.390887Z","shell.execute_reply.started":"2026-07-18T16:42:07.997581Z","shel